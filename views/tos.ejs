<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Terms of Service - <%= settings.storeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/markdown-it/dist/markdown-it.min.js"></script>

  <meta property="og:title" content="Terms of Service | <%= settings.storeName %>" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= settings.baseURL %>" />
  <meta property="og:image" content="<%= settings.logoPath %>" />
  <meta property="og:description" content="Read the detailed terms and conditions that govern the use of our products and services." />
  <meta name="theme-color" content="<%= settings.accentColor %>">
  <meta property="og:site_name" content="<%= settings.storeName %>" />
  <meta property="og:locale" content="en_US" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 4s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .particle {
      position: absolute;
      background: var(--accent-color);
      border-radius: 50%;
      pointer-events: none;
      animation: float 6s ease-in-out infinite;
    }

    .particle:nth-child(1) {
      top: 15%;
      left: 10%;
      width: 3px;
      height: 3px;
      animation-delay: 0s;
      opacity: 0.4;
    }

    .particle:nth-child(2) {
      top: 65%;
      left: 15%;
      width: 2px;
      height: 2px;
      animation-delay: 2s;
      opacity: 0.3;
    }

    .particle:nth-child(3) {
      top: 35%;
      right: 12%;
      width: 4px;
      height: 4px;
      animation-delay: 4s;
      opacity: 0.5;
    }

    .particle:nth-child(4) {
      bottom: 25%;
      left: 18%;
      width: 2px;
      height: 2px;
      animation-delay: 1s;
      opacity: 0.3;
    }

    .particle:nth-child(5) {
      bottom: 55%;
      right: 20%;
      width: 3px;
      height: 3px;
      animation-delay: 3s;
      opacity: 0.4;
    }

    .markdown-body {
      font-size: 1rem;
      line-height: 1.8;
      color: #ffffff;
    }

    .markdown-body h1 {
      font-size: 2.5rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1.5rem;
      margin-top: 2rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid rgba(var(--accent-rgb), 0.3);
    }

    .markdown-body h2 {
      font-size: 2rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1.25rem;
      margin-top: 2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .markdown-body h2::before {
      content: '';
      width: 4px;
      height: 1.5rem;
      background: var(--accent-color);
      border-radius: 2px;
    }

    .markdown-body h3 {
      font-size: 1.75rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1rem;
      margin-top: 1.5rem;
    }

    .markdown-body h4 {
      font-size: 1.5rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1rem;
      margin-top: 1.5rem;
    }

    .markdown-body p {
      font-size: 1rem;
      margin-bottom: 1.25rem;
      color: #a1a1aa;
      line-height: 1.8;
    }

    .markdown-body a {
      color: var(--accent-color);
      text-decoration: none;
      transition: all 0.2s ease;
      border-bottom: 1px solid transparent;
    }

    .markdown-body a:hover {
      border-bottom: 1px solid var(--accent-color);
    }

    .markdown-body ul,
    .markdown-body ol {
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
      list-style-type: disc;
      color: #a1a1aa;
    }

    .markdown-body ul li,
    .markdown-body ol li {
      margin-bottom: 0.5rem;
      line-height: 1.8;
    }

    .markdown-body ol {
      list-style-type: decimal;
    }

    .markdown-body strong,
    .markdown-body b {
      font-weight: bold;
      color: var(--accent-color);
    }

    .markdown-body em,
    .markdown-body i {
      font-style: italic;
      color: #ffffff;
    }

    .markdown-body code {
      background-color: #161b22;
      padding: 0.25rem 0.5rem;
      border-radius: 6px;
      font-family: 'Courier New', monospace;
      font-size: 0.9rem;
      color: var(--accent-color);
      border: 1px solid rgba(var(--accent-rgb), 0.2);
    }

    .markdown-body pre {
      background-color: #161b22;
      padding: 1.25rem;
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 1.25rem;
      border: 1px solid rgba(var(--accent-rgb), 0.2);
    }

    .markdown-body pre code {
      background: none;
      padding: 0;
      border: none;
      color: #ffffff;
    }

    .markdown-body blockquote {
      padding: 1rem 1.5rem;
      margin: 1.25rem 0;
      background: linear-gradient(90deg, rgba(var(--accent-rgb), 0.1) 0%, transparent 100%);
      border-left: 4px solid var(--accent-color);
      border-radius: 0 8px 8px 0;
      color: #ffffff;
    }

    .markdown-body blockquote p {
      color: #ffffff;
      margin-bottom: 0;
    }

    .markdown-body table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      background: rgba(26, 26, 26, 0.5);
      border-radius: 12px;
      overflow: hidden;
    }

    .markdown-body th,
    .markdown-body td {
      padding: 1rem;
      border: 1px solid rgba(var(--accent-rgb), 0.2);
      text-align: left;
    }

    .markdown-body th {
      background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.2) 0%, rgba(var(--accent-rgb), 0.1) 100%);
      font-weight: bold;
      color: #ffffff;
    }

    .markdown-body td {
      background-color: rgba(10, 10, 10, 0.5);
      color: #a1a1aa;
    }

    .markdown-body hr {
      border: none;
      height: 2px;
      background: linear-gradient(90deg, transparent, rgba(var(--accent-rgb), 0.5), transparent);
      margin: 2rem 0;
    }

    .markdown-body .info,
    .markdown-body .success,
    .markdown-body .warning,
    .markdown-body .danger {
      padding: 1rem 1.25rem;
      margin-bottom: 1.25rem;
      border-radius: 12px;
      color: #fff;
      border-left: 4px solid;
      display: flex;
      align-items: start;
      gap: 0.75rem;
    }

    .markdown-body .info {
      background: linear-gradient(135deg, rgba(1, 122, 205, 0.2) 0%, rgba(1, 122, 205, 0.05) 100%);
      border-left-color: #017acd;
    }

    .markdown-body .info::before {
      content: '\f05a';
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      color: #017acd;
    }

    .markdown-body .success {
      background: linear-gradient(135deg, rgba(40, 167, 69, 0.2) 0%, rgba(40, 167, 69, 0.05) 100%);
      border-left-color: #28a745;
    }

    .markdown-body .success::before {
      content: '\f058';
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      color: #28a745;
    }

    .markdown-body .warning {
      background: linear-gradient(135deg, rgba(211, 158, 0, 0.2) 0%, rgba(211, 158, 0, 0.05) 100%);
      border-left-color: #d39e00;
    }

    .markdown-body .warning::before {
      content: '\f071';
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      color: #d39e00;
    }

    .markdown-body .danger {
      background: linear-gradient(135deg, rgba(220, 53, 69, 0.2) 0%, rgba(220, 53, 69, 0.05) 100%);
      border-left-color: #dc3545;
    }

    .markdown-body .danger::before {
      content: '\f06a';
      font-family: 'Font Awesome 6 Free';
      font-weight: 900;
      color: #dc3545;
    }

    .markdown-body iframe {
      max-width: 100%;
      height: auto;
      aspect-ratio: 16/9;
      width: 100%;
      display: block;
      margin: 1.25rem auto;
      border-radius: 12px;
      border: 2px solid rgba(var(--accent-rgb), 0.2);
    }

    ::-webkit-scrollbar {
      width: 10px;
      height: 10px;
    }

    ::-webkit-scrollbar-track {
      background: #0a0a0a;
    }

    ::-webkit-scrollbar-thumb {
      background: rgba(var(--accent-rgb), 0.5);
      border-radius: 5px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: rgba(var(--accent-rgb), 0.7);
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('partials/navbar', { user, existingUser }) %>

  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden" style="
        background: linear-gradient(
            135deg,
            rgba(var(--accent-rgb), 0.25) 0%,
            rgba(0, 0, 0, 0.85) 30%,
            rgba(0, 0, 0, 0.90) 70%,
            rgba(var(--accent-rgb), 0.20) 100%
        );
    ">
    <div class="absolute inset-0">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="text-center max-w-4xl mx-auto">
        <div class="space-y-6" data-aos="fade-up" data-aos-duration="1000">
          <div class="inline-flex items-center gap-3 bg-dark-card/80 backdrop-blur-xl px-6 py-2 rounded-full mb-4 border border-accent/30">
            <i class="fas fa-file-contract text-accent"></i>
            <span class="text-sm text-text-secondary font-medium">Legal Document</span>
          </div>

          <h1 class="text-4xl lg:text-6xl font-black leading-tight text-white mb-4">
            <%= settings.tosPageTitle || 'Terms of Service' %>
          </h1>
          <p class="text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto">
            <%= settings.tosPageSubtitle || 'Please read these terms carefully before using our services.' %>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-dark-lighter">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="glass-effect rounded-2xl p-6 mb-8 hover-lift" data-aos="fade-up">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-accent/20 rounded-xl flex items-center justify-center">
                <i class="fas fa-clock text-accent text-xl"></i>
              </div>
              <div>
                <div class="text-sm text-text-secondary">Last Updated</div>
                <div class="text-lg font-semibold text-white">
                  <%= tosLastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                </div>
              </div>
            </div>

            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <i class="fas fa-info-circle text-accent"></i>
              <span>By using our services, you agree to these terms</span>
            </div>
          </div>
        </div>

        <div class="glass-effect rounded-2xl p-8 lg:p-12 hover-lift" data-aos="fade-up" data-aos-delay="200">
          <div class="markdown-body">
            <%- md.render(settings.termsOfService) %>
          </div>
        </div>
  </section>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });
  </script>

  <%- include('partials/footer') %>
</body>

</html>