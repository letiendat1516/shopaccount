<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Panel | Bundles</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.14.0/Sortable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 4s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .stat-accent-bar {
      height: 4px;
      background: var(--accent-color);
      opacity: 0.7;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.25rem 0.75rem;
      border-radius: 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-success {
      background-color: rgba(34, 197, 94, 0.2);
      color: #22c55e;
    }

    .badge-warning {
      background-color: rgba(234, 179, 8, 0.2);
      color: #eab308;
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('../partials/navbar', { user, existingUser }) %>

  <div class="min-h-screen bg-dark-lighter">
    <%- include('../partials/staff-navbar', { user, currentPage: 'bundles' }) %>

    <div class="container mx-auto px-6 py-8">
      <div class="mb-8" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h1 class="text-4xl font-bold text-white mb-2">Bundle Management</h1>
            <p class="text-text-secondary text-lg">Create and manage product bundles to boost sales with special offers and better deals.</p>
          </div>
          <div>
            <a href="/staff/bundles/create" class="bg-accent hover:bg-accent/90 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift">
              <i class="fas fa-plus"></i>
              <span>Create Bundle</span>
            </a>
          </div>
        </div>
      </div>

      <% if (bundles.length === 0) { %>
      <div class="glass-effect rounded-2xl p-12 text-center hover-lift" data-aos="fade-up">
        <div class="stat-accent-bar rounded-t-2xl -mx-12 -mt-12 mb-8"></div>
        <div class="w-24 h-24 bg-dark-card rounded-3xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-box-open text-accent text-4xl"></i>
        </div>
        <h3 class="text-3xl font-bold text-white mb-4">No bundles found</h3>
        <p class="text-text-secondary text-lg mb-8">You haven't created any product bundles yet. Start creating bundles to offer better deals to your customers!</p>
        <a href="/staff/bundles/create" class="bg-accent hover:bg-accent/90 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift mx-auto w-fit">
          <i class="fas fa-plus"></i>
          <span>Create Your First Bundle</span>
        </a>
      </div>
      <% } else { %>

      <div id="bundle-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <% bundles.forEach((bundle, index) => { %>
        <div class="glass-effect rounded-2xl hover-lift transition-all duration-300 overflow-hidden" data-id="<%= bundle._id %>" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
          <div class="stat-accent-bar"></div>

<div class="relative p-8 bg-gradient-to-br from-dark-card to-dark-border">
  <div class="absolute top-3 left-3">
    <span class="<%= bundle.active ? 'badge-success' : 'badge-warning' %> badge">
      <i class="fas <%= bundle.active ? 'fa-check-circle' : 'fa-pause-circle' %>"></i>
      <%= bundle.active ? 'Active' : 'Inactive' %>
    </span>
  </div>
  <div class="absolute top-3 right-3">
    <span class="badge bg-accent/90 text-white">
      <i class="fas fa-percentage"></i>
      <%= bundle.discountPercentage %>% OFF
    </span>
  </div>
  
  <div class="flex items-center justify-center">
    <div class="w-20 h-20 bg-accent/20 rounded-2xl flex items-center justify-center">
      <i class="fas fa-layer-group text-accent text-3xl"></i>
    </div>
  </div>
</div>

          <div class="p-6">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-bold text-white truncate" title="<%= bundle.name %>">
                    <%= bundle.name %>
                  </h3>
                </div>
              </div>
            </div>

            <div class="mb-4">
              <p class="text-text-secondary text-sm line-clamp-2"><%= bundle.description %></p>
            </div>

            <div class="flex items-center gap-2 mb-4">
              <div class="flex -space-x-2">
                <% bundle.products.slice(0, 3).forEach((product, i) => { %>
                <div class="w-8 h-8 rounded-lg bg-dark-card border-2 border-dark-card overflow-hidden" style="z-index: <%= 3 - i %>">
                  <img src="/<%= product.bannerImage %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                </div>
                <% }); %>
              </div>
              <span class="text-sm text-text-secondary">
                <%= bundle.products.length %> product<%= bundle.products.length !== 1 ? 's' : '' %>
              </span>
            </div>

            <div class="flex items-center justify-between py-4 border-t border-b border-white/10 mb-4">
              <div>
                <p class="text-text-secondary text-sm mb-1">Original Price</p>
                <p class="text-lg font-bold text-text-muted line-through">
                  <%= settings.currencySymbol %><%= bundle.originalPrice.toFixed(2) %>
                </p>
              </div>
              <div class="text-right">
                <p class="text-text-secondary text-sm mb-1">Bundle Price</p>
                <p class="text-xl font-bold text-accent">
                  <%= settings.currencySymbol %><%= bundle.bundlePrice.toFixed(2) %>
                </p>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-4">
              <div class="text-center p-3 bg-dark-card/50 rounded-lg">
                <p class="text-text-secondary text-xs mb-1">Purchases</p>
                <p class="text-lg font-bold text-white"><%= bundle.totalPurchases %></p>
              </div>
              <div class="text-center p-3 bg-dark-card/50 rounded-lg">
                <p class="text-text-secondary text-xs mb-1">Total Earned</p>
                <p class="text-lg font-bold text-accent"><%= settings.currencySymbol %><%= bundle.totalEarned.toFixed(2) %></p>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-2">

              <a href="/staff/bundles/edit/<%= bundle._id %>" class="flex items-center justify-center p-3 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded-lg transition-all duration-300 hover-lift" title="Edit Bundle">
                <i class="fas fa-edit"></i>
              </a>

              <form action="/staff/bundles/delete/<%= bundle._id %>" method="POST" class="inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="w-full flex items-center justify-center p-3 bg-red-500/20 hover:bg-red-500/30 text-red-400 rounded-lg transition-all duration-300 hover-lift" onclick="return confirm('Are you sure you want to delete this bundle? This action cannot be undone.');" title="Delete Bundle">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });
  </script>
</body>

</html>
