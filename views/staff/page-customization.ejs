  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });

    document.querySelectorAll('.nav-item').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href').substring(1);
        const target = document.getElementById(targetId);

        if (target) {
          const offset = 100;
          const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });

    const sections = document.querySelectorAll('.settings-section');
    const navItems = document.querySelectorAll('.nav-item');

    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        if (window.pageYOffset >= (sectionTop - 150)) {
          current = section.getAttribute('id');
        }
      });

      navItems.forEach(item => {
        item.classList.remove('active');
        if (item.getAttribute('href') === `#${current}`) {
          item.classList.add('active');
        }
      });
    });

    function addNavTab() {
      const container = document.getElementById('custom-nav-tabs');
      const index = container.querySelectorAll('.bg-dark-lighter').length;

      const emptyState = container.querySelector('.text-center');
      if (emptyState) emptyState.remove();

      const newTab = document.createElement('div');
      newTab.className = 'flex flex-col sm:flex-row gap-2 items-stretch sm:items-center bg-dark-lighter rounded-lg p-2 border border-white/10';
      newTab.innerHTML = `
                <input class="flex-1 bg-dark-card text-white border-0 rounded px-3 py-1.5 text-sm" type="text" name="customNavTabs[${index}][name]" placeholder="Link Text" required>
                <input class="flex-1 bg-dark-card text-white border-0 rounded px-3 py-1.5 text-sm" type="text" name="customNavTabs[${index}][link]" placeholder="https://..." required>
                <button type="button" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded transition-all w-full sm:w-auto" onclick="removeNavTab(this)">
                    <i class="fas fa-trash text-sm"></i>
                </button>
            `;
      container.appendChild(newTab);
    }

    function removeNavTab(button) {
      const container = document.getElementById('custom-nav-tabs');
      button.closest('.bg-dark-lighter').remove();

      if (container.querySelectorAll('.bg-dark-lighter').length === 0) {
        container.innerHTML = `
                    <div class="text-center py-6 bg-dark-card rounded-xl">
                        <i class="fas fa-link text-text-muted text-2xl mb-2"></i>
                        <p class="text-text-secondary text-sm">No custom links added yet</p>
                    </div>
                `;
      }
    }

    function addFAQ() {
      const container = document.getElementById('custom-faqs');
      const index = container.querySelectorAll('.bg-dark-card').length;

      const emptyState = document.getElementById('emptyFAQState');
      if (emptyState) emptyState.remove();

      const newFAQ = document.createElement('div');
      newFAQ.className = 'bg-dark-card rounded-xl p-4 border border-white/10';
      newFAQ.innerHTML = `
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-medium text-text-secondary mb-1">Question</label>
                <input 
                    class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2 text-sm focus:border-accent focus:outline-none transition-colors" 
                    type="text" 
                    name="faqs[${index}][question]" 
                    placeholder="e.g., How do I install the product?" 
                    required
                >
            </div>
            <div>
                <label class="block text-xs font-medium text-text-secondary mb-1">Answer</label>
                <textarea 
                    class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2 text-sm focus:border-accent focus:outline-none transition-colors resize-none" 
                    name="faqs[${index}][answer]" 
                    rows="3"
                    placeholder="Provide a detailed answer..."
                    required></textarea>
            </div>
            <div class="flex justify-end">
                <button 
                    type="button" 
                    class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded transition-all text-sm" 
                    onclick="removeFAQ(this)"
                >
                    <i class="fas fa-trash text-sm mr-1"></i> Remove
                </button>
            </div>
        </div>
    `;
      container.appendChild(newFAQ);
    }

    function removeFAQ(button) {
      const container = document.getElementById('custom-faqs');
      button.closest('.bg-dark-card').remove();

      if (container.querySelectorAll('.bg-dark-card').length === 0) {
        container.innerHTML = `
            <div class="text-center py-6 bg-dark-card rounded-xl" id="emptyFAQState">
                <i class="fas fa-question-circle text-text-muted text-2xl mb-2"></i>
                <p class="text-text-secondary text-sm">No FAQs added yet</p>
            </div>
        `;
      }
    }

    function addFooterTab() {
      const container = document.getElementById('custom-footer-tabs');
      const index = container.querySelectorAll('.bg-dark-lighter').length;

      const emptyState = container.querySelector('.text-center');
      if (emptyState) emptyState.remove();

      const newTab = document.createElement('div');
      newTab.className = 'flex flex-col sm:flex-row gap-2 items-stretch sm:items-center bg-dark-lighter rounded-lg p-2 border border-white/10';
      newTab.innerHTML = `
                <input class="flex-1 bg-dark-card text-white border-0 rounded px-3 py-1.5 text-sm" type="text" name="customFooterTabs[${index}][name]" placeholder="Link Text" required>
                <input class="flex-1 bg-dark-card text-white border-0 rounded px-3 py-1.5 text-sm" type="text" name="customFooterTabs[${index}][link]" placeholder="https://..." required>
                <button type="button" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded transition-all w-full sm:w-auto" onclick="removeFooterTab(this)">
                    <i class="fas fa-trash text-sm"></i>
                </button>
            `;
      container.appendChild(newTab);
    }

    function removeFooterTab(button) {
      const container = document.getElementById('custom-footer-tabs');
      button.closest('.bg-dark-lighter').remove();

      if (container.querySelectorAll('.bg-dark-lighter').length === 0) {
        container.innerHTML = `
                    <div class="text-center py-6 bg-dark-card rounded-xl">
                        <i class="fas fa-link text-text-muted text-2xl mb-2"></i>
                        <p class="text-text-secondary text-sm">No footer links added yet</p>
                    </div>
                `;
      }
    }

    const holidayEffectsToggle = document.getElementById('holidayEffectsToggle');
    const holidayEffectsOptions = document.getElementById('holidayEffectsOptions');

    if (holidayEffectsToggle) {
      holidayEffectsToggle.addEventListener('change', function() {
        if (this.checked) {
          holidayEffectsOptions.classList.remove('hidden');
        } else {
          holidayEffectsOptions.classList.add('hidden');
        }
      });
    }

    function addFeature() {
      const container = document.getElementById('custom-features');
      const index = container.querySelectorAll('.feature-card').length;

      const emptyState = document.getElementById('emptyFeaturesState');
      if (emptyState) emptyState.remove();

      const newFeature = document.createElement('div');
      newFeature.className = 'feature-card bg-gradient-to-br from-dark-card to-dark-lighter rounded-xl p-5 border border-white/10 hover:border-accent/50 transition-all duration-300';
      newFeature.innerHTML = `
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-accent/20 to-accent/10 rounded-lg flex items-center justify-center">
                    <span class="text-accent font-bold text-sm">#${index + 1}</span>
                </div>
                <h3 class="text-sm font-semibold text-white">Feature ${index + 1}</h3>
            </div>
            <button 
                type="button" 
                class="bg-red-600/20 hover:bg-red-600 text-red-400 hover:text-white px-3 py-1.5 rounded-lg transition-all text-sm border border-red-600/30 hover:border-red-600" 
                onclick="removeFeature(this)"
            >
                <i class="fas fa-trash text-xs mr-1"></i> Remove
            </button>
        </div>
        
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-medium text-text-secondary mb-2">
                    <i class="fas fa-icons mr-1"></i> Icon Class
                </label>
                <div class="flex gap-2">
                    <div class="relative flex-1">
                        <input 
                            class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg pl-10 pr-3 py-2.5 text-sm focus:border-accent focus:outline-none transition-colors" 
                            type="text" 
                            name="features[${index}][icon]" 
                            placeholder="fas fa-star" 
                            oninput="updateIconPreview(this)"
                            required
                        >
                        <div class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 bg-accent/20 rounded flex items-center justify-center icon-preview">
                            <i class="fas fa-star text-accent text-xs"></i>
                        </div>
                    </div>
                    <a 
                        href="https://fontawesome.com/search?o=r&m=free" 
                        target="_blank" 
                        class="bg-blue-600/20 hover:bg-blue-600 text-blue-400 hover:text-white px-4 py-2.5 rounded-lg transition-all text-sm border border-blue-600/30 hover:border-blue-600 flex items-center gap-2 whitespace-nowrap"
                    >
                        <i class="fab fa-font-awesome"></i>
                        <span class="hidden sm:inline">Browse</span>
                    </a>
                </div>
                <p class="text-xs text-text-muted mt-1.5">
                    <i class="fas fa-info-circle mr-1"></i>
                    Popular: fa-rocket, fa-shield-alt, fa-bolt, fa-star, fa-heart
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs font-medium text-text-secondary mb-2">
                        <i class="fas fa-heading mr-1"></i> Title
                    </label>
                    <input 
                        class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2.5 text-sm focus:border-accent focus:outline-none transition-colors" 
                        type="text" 
                        name="features[${index}][title]" 
                        placeholder="Fast & Reliable" 
                        maxlength="30"
                        oninput="updateFeaturePreview(this)"
                        required
                    >
                    <p class="text-xs text-text-muted mt-1">Keep it short and catchy</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-text-secondary mb-2">
                        <i class="fas fa-align-left mr-1"></i> Description
                    </label>
                    <textarea 
                        class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2.5 text-sm focus:border-accent focus:outline-none transition-colors resize-none" 
                        name="features[${index}][description]" 
                        rows="2"
                        placeholder="Brief description of this feature..."
                        maxlength="100"
                        oninput="updateFeaturePreview(this)"
                        required></textarea>
                    <p class="text-xs text-text-muted mt-1">Max 100 characters</p>
                </div>
            </div>

            <div class="bg-dark-card/50 rounded-lg p-4 border border-white/5">
                <p class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-3">
                    <i class="fas fa-eye mr-1"></i> Preview
                </p>
                <div class="flex items-start gap-3">
                    <div class="w-12 h-12 bg-gradient-to-br from-accent/20 to-accent/5 rounded-xl flex items-center justify-center flex-shrink-0 feature-preview-icon">
                        <i class="fas fa-star text-accent text-xl"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <h4 class="text-sm font-bold text-white mb-1 feature-preview-title">Your Feature Title</h4>
                        <p class="text-xs text-text-secondary leading-relaxed feature-preview-description">Your feature description will appear here...</p>
                    </div>
                </div>
            </div>
        </div>
    `;
      container.appendChild(newFeature);

      newFeature.scrollIntoView({
        behavior: 'smooth',
        block: 'center'
      });
    }

    function removeFeature(button) {
      const container = document.getElementById('custom-features');
      const featureCard = button.closest('.feature-card');

      featureCard.style.opacity = '0';
      featureCard.style.transform = 'scale(0.95)';
      featureCard.style.transition = 'all 0.2s ease';

      setTimeout(() => {
        featureCard.remove();

        container.querySelectorAll('.feature-card').forEach((card, index) => {
          const badge = card.querySelector('.text-accent');
          if (badge) badge.textContent = `#${index + 1}`;

          const heading = card.querySelector('h3');
          if (heading) heading.textContent = `Feature ${index + 1}`;
        });

        if (container.querySelectorAll('.feature-card').length === 0) {
          container.innerHTML = `
                <div class="text-center py-12 bg-dark-card rounded-xl border border-dashed border-white/10" id="emptyFeaturesState">
                    <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-boxes text-accent text-2xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2">No Features Added Yet</h3>
                    <p class="text-text-secondary text-sm mb-4">Start showcasing your product's best features</p>
                    <button 
                        type="button" 
                        class="inline-flex items-center gap-2 bg-accent hover:bg-accent/90 text-white px-6 py-2.5 rounded-lg font-semibold transition-all text-sm" 
                        onclick="addFeature()"
                    >
                        <i class="fas fa-plus"></i>
                        <span>Add Your First Feature</span>
                    </button>
                </div>
            `;
        }
      }, 200);
    }

    function updateIconPreview(input) {
      const featureCard = input.closest('.feature-card');
      const iconPreview = featureCard.querySelector('.icon-preview i');
      const previewIcon = featureCard.querySelector('.feature-preview-icon i');

      if (iconPreview && input.value.trim()) {
        iconPreview.className = `${input.value.trim()} text-accent text-xs`;
      }

      if (previewIcon && input.value.trim()) {
        previewIcon.className = `${input.value.trim()} text-accent text-xl`;
      }
    }

    function updateFeaturePreview(input) {
      const featureCard = input.closest('.feature-card');
      const previewTitle = featureCard.querySelector('.feature-preview-title');
      const previewDescription = featureCard.querySelector('.feature-preview-description');

      if (input.name.includes('[title]') && previewTitle) {
        previewTitle.textContent = input.value || 'Your Feature Title';
      }

      if (input.name.includes('[description]') && previewDescription) {
        previewDescription.textContent = input.value || 'Your feature description will appear here...';
      }
    }
  </script>
</body>

</html>