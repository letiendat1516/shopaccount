<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Panel | Invoices</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 4s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .stat-accent-bar {
      height: 4px;
      background: var(--accent-color);
      opacity: 0.7;
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('../partials/navbar', { user, existingUser }) %>

  <div class="min-h-screen bg-dark-lighter">
    <%- include('../partials/staff-navbar', { user, currentPage: 'invoices' }) %>

    <div class="container mx-auto px-6 py-8">
      <div class="mb-8" data-aos="fade-up">
        <h1 class="text-4xl font-bold text-white mb-2">Invoice Management</h1>
        <p class="text-text-secondary text-lg">View and manage all payment transactions on your platform.</p>
      </div>

      <div class="glass-effect rounded-2xl p-6 mb-8 hover-lift" data-aos="fade-up">
        <form method="GET" action="/staff/invoices" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="lg:col-span-2">
              <label class="block text-sm font-medium text-text-secondary mb-2">
                <i class="fas fa-search mr-2"></i>Search
              </label>
              <input type="text" name="search" value="<%= search %>" placeholder="Search by invoice ID, transaction ID, or username..." class="w-full bg-dark-card text-white border border-white/20 rounded-lg px-4 py-3 focus:border-accent focus:outline-none transition-colors" />
            </div>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">
                <i class="fas fa-credit-card mr-2"></i>Payment Method
              </label>
              <select name="paymentMethod" class="w-full bg-dark-card text-white border border-white/20 rounded-lg px-4 py-3 focus:border-accent focus:outline-none transition-colors">
                <option value="" <%= paymentMethod === '' ? 'selected' : '' %>>All Payment Methods</option>
                <option value="paypal" <%= paymentMethod === 'paypal' ? 'selected' : '' %>>PayPal</option>
                <option value="stripe" <%= paymentMethod === 'stripe' ? 'selected' : '' %>>Stripe</option>
                <option value="coinbase" <%= paymentMethod === 'coinbase' ? 'selected' : '' %>>Coinbase</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">
                <i class="fas fa-calendar-alt mr-2"></i>Start Date
              </label>
              <input type="date" name="startDate" value="<%= startDate %>" class="w-full bg-dark-card text-white border border-white/20 rounded-lg px-4 py-3 focus:border-accent focus:outline-none transition-colors" />
            </div>

            <div>
              <label class="block text-sm font-medium text-text-secondary mb-2">
                <i class="fas fa-calendar-alt mr-2"></i>End Date
              </label>
              <input type="date" name="endDate" value="<%= endDate %>" class="w-full bg-dark-card text-white border border-white/20 rounded-lg px-4 py-3 focus:border-accent focus:outline-none transition-colors" />
            </div>

            <button type="submit" class="w-full bg-accent hover:bg-accent/90 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center justify-center gap-3 hover-lift">
              <i class="fas fa-filter"></i>
              <span>Apply Filters</span>
            </button>
          </div>

          <% if (hasFilters) { %>
          <div class="flex flex-wrap gap-3 pt-4 border-t border-white/10">
            <% if (search) { %>
            <div class="flex items-center gap-2 bg-accent/20 text-white px-3 py-1.5 rounded-lg text-sm">
              <span class="text-text-secondary">Search:</span>
              <span class="font-semibold"><%= search %></span>
              <a href="<%= removeFilterUrl('search') %>" class="ml-1 hover:text-red-400 transition-colors">
                <i class="fas fa-times"></i>
              </a>
            </div>
            <% } %>

            <% if (paymentMethod) { %>
            <div class="flex items-center gap-2 bg-accent/20 text-white px-3 py-1.5 rounded-lg text-sm">
              <span class="text-text-secondary">Payment:</span>
              <span class="font-semibold"><%= paymentMethod.charAt(0).toUpperCase() + paymentMethod.slice(1) %></span>
              <a href="<%= removeFilterUrl('paymentMethod') %>" class="ml-1 hover:text-red-400 transition-colors">
                <i class="fas fa-times"></i>
              </a>
            </div>
            <% } %>

            <% if (status) { %>
            <div class="flex items-center gap-2 bg-accent/20 text-white px-3 py-1.5 rounded-lg text-sm">
              <span class="text-text-secondary">Status:</span>
              <span class="font-semibold"><%= status.charAt(0).toUpperCase() + status.slice(1) %></span>
              <a href="<%= removeFilterUrl('status') %>" class="ml-1 hover:text-red-400 transition-colors">
                <i class="fas fa-times"></i>
              </a>
            </div>
            <% } %>

            <% if (startDate) { %>
            <div class="flex items-center gap-2 bg-accent/20 text-white px-3 py-1.5 rounded-lg text-sm">
              <span class="text-text-secondary">From:</span>
              <span class="font-semibold"><%= new Date(startDate).toLocaleDateString() %></span>
              <a href="<%= removeFilterUrl('startDate') %>" class="ml-1 hover:text-red-400 transition-colors">
                <i class="fas fa-times"></i>
              </a>
            </div>
            <% } %>

            <% if (endDate) { %>
            <div class="flex items-center gap-2 bg-accent/20 text-white px-3 py-1.5 rounded-lg text-sm">
              <span class="text-text-secondary">To:</span>
              <span class="font-semibold"><%= new Date(endDate).toLocaleDateString() %></span>
              <a href="<%= removeFilterUrl('endDate') %>" class="ml-1 hover:text-red-400 transition-colors">
                <i class="fas fa-times"></i>
              </a>
            </div>
            <% } %>

            <a href="/staff/invoices" class="flex items-center gap-2 bg-red-500/20 hover:bg-red-500/30 text-red-400 px-3 py-1.5 rounded-lg text-sm transition-colors hover-lift">
              <i class="fas fa-trash-alt"></i>
              <span>Clear all filters</span>
            </a>
          </div>
          <% } %>
        </form>
      </div>

      <% if (invoices.length === 0) { %>
      <div class="glass-effect rounded-2xl p-12 text-center hover-lift" data-aos="fade-up">
        <div class="stat-accent-bar rounded-t-2xl -mx-12 -mt-12 mb-8"></div>
        <div class="w-24 h-24 bg-dark-card rounded-3xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-file-invoice-dollar text-accent text-4xl"></i>
        </div>
        <h3 class="text-3xl font-bold text-white mb-4">No invoices found</h3>
        <p class="text-text-secondary text-lg mb-8">
          There are no invoices matching your search criteria. Try adjusting your search or view all invoices.
        </p>
        <a href="/staff/invoices" class="inline-flex items-center gap-3 bg-accent hover:bg-accent/90 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-300 hover-lift">
          <i class="fas fa-eye"></i>
          <span>View All Invoices</span>
        </a>
      </div>
      <% } else { %>
      <div class="space-y-3">
        <% invoices.forEach((invoice, index) => { %>
        <div class="glass-effect rounded-xl overflow-hidden hover-lift" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
          <div class="stat-accent-bar"></div>

          <div class="p-4">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
              <div class="flex items-center gap-4 flex-wrap flex-1">
                <div class="flex items-center gap-2">
                  <i class="fas fa-hashtag text-accent text-sm"></i>
                  <span class="text-lg font-bold text-accent">#<%= invoice.ID %></span>
                </div>

                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-green-500/20 text-green-400 rounded-lg text-xs font-semibold">
                  <i class="fas fa-check-circle text-xs"></i>
                  Completed
                </span>

                <div class="flex items-center gap-2 text-text-secondary text-sm">
                  <i class="fas fa-calendar-alt text-xs"></i>
                  <span><%= new Date(invoice.createdAt).toLocaleString('en-US', { 
                                                month: 'short', 
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            }) %></span>
                </div>

                <div class="flex items-center gap-2 text-text-secondary text-sm">
                  <% if (invoice.paymentMethod === 'paypal') { %>
                  <i class="fab fa-paypal text-accent text-sm"></i>
                  <span>PayPal</span>
                  <% } else if (invoice.paymentMethod === 'stripe') { %>
                  <i class="fab fa-stripe text-accent text-sm"></i>
                  <span>Stripe</span>
                  <% } else if (invoice.paymentMethod === 'coinbase') { %>
                  <i class="fab fa-bitcoin text-accent text-sm"></i>
                  <span>Coinbase</span>
                  <% } else { %>
                  <i class="fas fa-money-bill text-accent text-sm"></i>
                  <span><%= invoice.paymentMethod || 'Unknown' %></span>
                  <% } %>
                </div>

                <a href="/profile/<%= invoice.userID %>" class="inline-flex items-center gap-2 hover:text-accent transition-colors text-sm">
                  <img src="<%= invoice.userAvatar %>" alt="User" class="w-5 h-5 rounded-full">
                  <span class="font-semibold"><%= invoice.username %></span>
                </a>
              </div>

              <div class="text-left lg:text-right">
                <div class="text-xl font-bold text-accent">
                  <%= settings.currencySymbol %><%= (invoice.totalPaid !== undefined) ? invoice.totalPaid.toFixed(2) : '0.00' %>
                </div>
              </div>
            </div>

            <div class="mt-3 pt-3 border-t border-white/10">
              <div class="flex flex-col lg:flex-row lg:items-center gap-3">
                <div class="flex-1">
                  <div class="flex items-center gap-2 text-text-secondary mb-2 text-xs">
                    <i class="fas fa-shopping-bag"></i>
                    <span class="font-semibold">Items:</span>
                  </div>
                  <div class="flex flex-wrap gap-1.5">
                    <% invoice.products.forEach(product => { %>
                    <span class="px-2 py-1 bg-accent/20 text-accent rounded text-xs font-semibold">
                      <%= product.name %>
                    </span>
                    <% }); %>
                  </div>
                </div>

                <div class="flex flex-wrap gap-2 lg:justify-end">
                  <a href="/invoice/<%= invoice.transactionID %>" class="px-3 py-1.5 bg-accent hover:bg-accent/90 text-white rounded-lg text-xs font-semibold transition-all duration-300 flex items-center gap-1.5 hover-lift">
                    <i class="fas fa-eye"></i>
                    <span>Details</span>
                  </a>

                  <% if (invoice.invoicePath) { %>
                  <a href="/invoice/<%= invoice.transactionID %>/view" target="_blank" class="px-3 py-1.5 bg-dark-card hover:bg-dark-border text-white border border-white/20 rounded-lg text-xs font-semibold transition-all duration-300 flex items-center gap-1.5 hover-lift">
                    <i class="fas fa-file-pdf"></i>
                    <span>PDF</span>
                  </a>
                  <% } %>

                  <a href="/profile/<%= invoice.userID %>" class="px-3 py-1.5 bg-dark-card hover:bg-dark-border text-white border border-white/20 rounded-lg text-xs font-semibold transition-all duration-300 flex items-center gap-1.5 hover-lift">
                    <i class="fas fa-user"></i>
                    <span>Customer</span>
                  </a>
                </div>
              </div>

              <div class="mt-2 flex items-center gap-2 text-text-muted text-xs">
                <i class="fas fa-receipt"></i>
                <span class="font-mono">
                  <%= invoice.transactionID ? (invoice.transactionID.length > 30 ? invoice.transactionID.substring(0, 30) + '...' : invoice.transactionID) : 'N/A' %>
                </span>
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>

      <div class="flex justify-center mt-12" data-aos="fade-up">
        <nav class="glass-effect rounded-xl overflow-hidden inline-flex">
          <% if (currentPage > 1) { %>
          <a href="/staff/invoices?page=<%= currentPage - 1 %>&search=<%= search %>&paymentMethod=<%= paymentMethod %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300 border-r border-white/10">
            <i class="fas fa-chevron-left"></i>
          </a>
          <% } else { %>
          <span class="px-4 py-3 bg-dark-card text-text-muted cursor-not-allowed border-r border-white/10">
            <i class="fas fa-chevron-left"></i>
          </span>
          <% } %>

          <% 
                            let startPage = Math.max(1, currentPage - 2);
                            let endPage = Math.min(totalPages, currentPage + 2);
                            
                            if (startPage > 1) { 
                        %>
          <a href="/staff/invoices?page=1&search=<%= search %>&paymentMethod=<%= paymentMethod %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300 border-r border-white/10">
            1
          </a>

          <% if (startPage > 2) { %>
          <span class="px-4 py-3 bg-dark-card text-text-muted border-r border-white/10">...</span>
          <% } %>
          <% } %>

          <% for (let i = startPage; i <= endPage; i++) { %>
          <a href="/staff/invoices?page=<%= i %>&search=<%= search %>&paymentMethod=<%= paymentMethod %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>" class="px-4 py-3 <%= currentPage === i ? 'bg-accent text-white' : 'bg-dark-card hover:bg-accent text-text-secondary hover:text-white' %> transition-all duration-300 border-r border-white/10 font-semibold">
            <%= i %>
          </a>
          <% } %>

          <% if (endPage < totalPages) { %>
          <% if (endPage < totalPages - 1) { %>
          <span class="px-4 py-3 bg-dark-card text-text-muted border-r border-white/10">...</span>
          <% } %>

          <a href="/staff/invoices?page=<%= totalPages %>&search=<%= search %>&paymentMethod=<%= paymentMethod %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300 border-r border-white/10">
            <%= totalPages %>
          </a>
          <% } %>

          <% if (currentPage < totalPages) { %>
          <a href="/staff/invoices?page=<%= currentPage + 1 %>&search=<%= search %>&paymentMethod=<%= paymentMethod %>&status=<%= status %>&startDate=<%= startDate %>&endDate=<%= endDate %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300">
            <i class="fas fa-chevron-right"></i>
          </a>
          <% } else { %>
          <span class="px-4 py-3 bg-dark-card text-text-muted cursor-not-allowed">
            <i class="fas fa-chevron-right"></i>
          </span>
          <% } %>
        </nav>
      </div>
      <% } %>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });
  </script>
</body>

</html>