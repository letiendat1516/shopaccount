<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Panel | Products</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.14.0/Sortable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 4s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .stat-accent-bar {
      height: 4px;
      background: var(--accent-color);
      opacity: 0.7;
    }

    .drag-handle {
      cursor: grab;
    }

    .drag-handle:active {
      cursor: grabbing;
    }

    body.dragging * {
      cursor: grabbing !important;
      user-select: none !important;
    }

    .sortable-ghost {
      opacity: 0.5;
      background-color: rgba(var(--accent-rgb), 0.1);
      border: 2px dashed var(--accent-color) !important;
    }

    .sortable-chosen {
      opacity: 0.8;
    }

    .sortable-drag {
      opacity: 0.8;
      transform: rotate(2deg);
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('../partials/navbar', { user, existingUser }) %>

  <div class="min-h-screen bg-dark-lighter">
    <%- include('../partials/staff-navbar', { user, currentPage: 'products' }) %>

    <div class="container mx-auto px-6 py-8">
      <div class="mb-8" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h1 class="text-4xl font-bold text-white mb-2">Products Management</h1>
            <p class="text-text-secondary text-lg">Manage all products available on your platform. Organize, edit, and control your product listings.</p>
          </div>
          <% if (staffPermissions && (staffPermissions.canCreateProducts || isOwner)) { %>
          <div>
            <a href="/staff/products/create" class="bg-accent hover:bg-accent/90 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift">
              <i class="fas fa-plus"></i>
              <span>Create a Product</span>
            </a>
          </div>
          <% } %>
        </div>
      </div>

      <% if (products.length === 0) { %>
      <div class="glass-effect rounded-2xl p-12 text-center hover-lift" data-aos="fade-up">
        <div class="stat-accent-bar rounded-t-2xl -mx-12 -mt-12 mb-8"></div>
        <div class="w-24 h-24 bg-dark-card rounded-3xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-box-open text-accent text-4xl"></i>
        </div>
        <h3 class="text-3xl font-bold text-white mb-4">No products found</h3>
        <p class="text-text-secondary text-lg mb-8">You haven't added any products yet.</p>
        <a href="/staff/products/create" class="bg-accent hover:bg-accent/90 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift mx-auto w-fit">
          <i class="fas fa-plus"></i>
          <span>Create Your First Product</span>
        </a>
      </div>
      <% } else { %>
      <div class="glass-effect rounded-2xl p-6 mb-8 hover-lift" data-aos="fade-up">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-accent/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <i class="fas fa-info-circle text-accent text-xl"></i>
          </div>
          <div>
            <p class="text-white font-semibold mb-1">Drag & Drop to Reorder</p>
            <p class="text-text-secondary">Use the drag handle <i class="fas fa-grip-lines text-accent"></i> to reorder products. Changes are saved automatically!</p>
          </div>
        </div>
      </div>

      <div id="product-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <% products.forEach((product, index) => { %>
        <div class="glass-effect rounded-2xl hover-lift transition-all duration-300 overflow-hidden" data-id="<%= product._id %>" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
          <div class="stat-accent-bar"></div>

          <div class="relative h-48 overflow-hidden bg-dark-card">
            <img src="/<%= product.bannerImage %>" alt="<%= product.name %>" class="w-full h-full object-cover">
            <div class="absolute top-3 right-3">
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-dark-card/90 backdrop-blur-sm border border-accent/30 text-accent rounded-lg text-sm font-semibold shadow-lg">
                <% if (product.productType === 'digitalPaid') { %>
                <i class="fas fa-dollar-sign"></i> Paid
                <% } else if (product.productType === 'digitalFree') { %>
                <i class="fas fa-gift"></i> Free
                <% } else if (product.productType === 'serials') { %>
                <i class="fas fa-key"></i> Serial
                <% } else if (product.productType === 'service') { %>
                <i class="fas fa-cogs"></i> Service
                <% } %>
              </span>
            </div>
          </div>

          <div class="p-6">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="drag-handle w-8 h-8 bg-accent/20 rounded-lg flex items-center justify-center flex-shrink-0 hover:bg-accent/30 transition-colors">
                  <i class="fas fa-grip-lines text-accent"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-bold text-white truncate" title="<%= product.name %>">
                    <%= product.name %>
                  </h3>
                  <span class="inline-flex items-center gap-1 px-2 py-1 bg-accent/20 text-accent rounded-lg text-xs font-semibold mt-1">
                    #<%= product.position %>
                  </span>
                </div>
              </div>
            </div>

            <div class="flex items-center justify-between py-4 border-t border-b border-white/10 mb-4">
              <div>
                <p class="text-text-secondary text-sm mb-1">Price</p>
                <p class="text-xl font-bold <%= product.productType === 'digitalFree' ? 'text-green-400' : 'text-accent' %>">
                  <% if (product.productType === 'digitalFree') { %>
                  Free
                  <% } else { %>
                  <%= settings.currencySymbol %><%= product.price.toFixed(2) %>
                  <% } %>
                </p>
              </div>

              <% if (product.productType !== 'digitalFree') { %>
              <div class="text-right">
                <p class="text-text-secondary text-sm mb-1">Total Earnings</p>
                <p class="text-xl font-bold text-accent">
                  <%= settings.currencySymbol %><%= product.totalEarned.toFixed(2) %>
                </p>
              </div>
              <% } %>
            </div>

            <div class="grid grid-cols-4 gap-2">
              <a href="/products/<%= product.urlId %>" class="flex items-center justify-center p-3 bg-green-500/20 hover:bg-green-500/30 text-green-400 rounded-lg transition-all duration-300 hover-lift" title="View Product">
                <i class="fas fa-eye"></i>
              </a>

              <% if (staffPermissions && (staffPermissions.canUpdateProducts || isOwner)) { %>
              <% if ((product.productType !== 'serials' && product.productType !== 'service') || 
        (product.productType === 'serials' && product.serialRequiresFile)) { %>
              <a href="/staff/products/update/<%= product._id %>" class="flex items-center justify-center p-3 bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 rounded-lg transition-all duration-300 hover-lift" title="Update Files">
                <i class="fas fa-upload"></i>
              </a>
              <% } else { %>
              <button class="flex items-center justify-center p-3 bg-gray-500/20 text-gray-500 rounded-lg cursor-not-allowed opacity-50" disabled title="Update not available for this product type">
                <i class="fas fa-upload"></i>
              </button>
              <% } %>
              <% } %>

              <% if (staffPermissions && (staffPermissions.canUpdateProducts || isOwner)) { %>
              <a href="/staff/products/edit/<%= product._id %>" class="flex items-center justify-center p-3 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded-lg transition-all duration-300 hover-lift" title="Edit Details">
                <i class="fas fa-edit"></i>
              </a>
              <% } %>

              <% if (staffPermissions && (staffPermissions.canDeleteProducts || isOwner)) { %>
              <form action="/staff/products/delete/<%= product._id %>" method="POST" class="inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="w-full flex items-center justify-center p-3 bg-red-500/20 hover:bg-red-500/30 text-red-400 rounded-lg transition-all duration-300 hover-lift" onclick="return confirm('Are you sure you want to delete this product?');" title="Delete Product">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });

    const productGrid = document.getElementById('product-grid');

    if (productGrid) {
      new Sortable(productGrid, {
        animation: 150,
        ghostClass: 'sortable-ghost',
        chosenClass: 'sortable-chosen',
        dragClass: 'sortable-drag',
        handle: '.drag-handle',
        onStart: () => {
          document.body.classList.add('dragging');
        },
        onEnd: async (evt) => {
          document.body.classList.remove('dragging');

          const productOrder = Array.from(productGrid.children).map((card, index) => {
            const positionBadge = card.querySelector('span.inline-flex.items-center.gap-1');
            if (positionBadge) {
              positionBadge.textContent = `#${index + 1}`;
            }
            return card.getAttribute('data-id');
          });

          const csrfToken = '<%= encodeURIComponent(csrfToken) %>';

          try {
            const response = await fetch(`/staff/products/sort?_csrf=${csrfToken}`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({
                productOrder
              }),
            });

            const data = await response.json();

            if (data.success) {
              console.log('Product order updated successfully.');
            } else {
              console.warn(`Failed to update product order: ${data.message}`);
            }
          } catch (error) {
            console.error('Error updating product order:', error);
          }
        },
      });
    }
  </script>
</body>

</html>