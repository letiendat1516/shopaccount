<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Staff Panel | Discount Codes</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 4s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .stat-accent-bar {
      height: 4px;
      background: var(--accent-color);
      opacity: 0.7;
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('../partials/navbar', { user, existingUser }) %>

  <div class="min-h-screen bg-dark-lighter">
    <%- include('../partials/staff-navbar', { user, currentPage: 'discount-codes' }) %>

    <div class="container mx-auto px-6 py-8">
      <div class="mb-8" data-aos="fade-up">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h1 class="text-4xl font-bold text-white mb-2">Discount Codes Management</h1>
            <p class="text-text-secondary text-lg">Create and manage discount codes for your products. Offer special promotions to boost sales.</p>
          </div>
          <div>
            <a href="/staff/discount-codes/create" class="bg-accent hover:bg-accent/90 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift">
              <i class="fas fa-plus"></i>
              <span>Create Discount Code</span>
            </a>
          </div>
        </div>
      </div>

      <% if (codes.length === 0) { %>
      <div class="glass-effect rounded-2xl p-12 text-center hover-lift overflow-hidden" data-aos="fade-up">
        <div class="stat-accent-bar -mx-12 -mt-12 mb-8"></div>
        <div class="w-24 h-24 bg-dark-card rounded-3xl flex items-center justify-center mx-auto mb-6">
          <i class="fas fa-tags text-accent text-4xl"></i>
        </div>
        <h3 class="text-3xl font-bold text-white mb-4">No discount codes found</h3>
        <p class="text-text-secondary text-lg mb-8">You haven't created any discount codes yet.</p>
        <a href="/staff/discount-codes/create" class="bg-accent hover:bg-accent/90 text-white px-8 py-4 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift mx-auto w-fit">
          <i class="fas fa-plus"></i>
          <span>Create Your First Discount Code</span>
        </a>
      </div>
      <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <% codes.forEach((code, index) => { 
                        const isExpired = code.expiresAt && new Date(code.expiresAt) < new Date();
                        const expiresSoon = code.expiresAt && !isExpired && (new Date(code.expiresAt) - new Date()) / (1000 * 60 * 60 * 24) < 7;
                        const usageRatio = code.maxUses ? code.uses / code.maxUses : 0;
                        const almostUsed = code.maxUses && usageRatio >= 0.8 && usageRatio < 1;
                        const fullyUsed = code.maxUses && code.uses >= code.maxUses;
                    %>
        <div class="glass-effect rounded-2xl hover-lift transition-all duration-300 overflow-hidden" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
          <div class="stat-accent-bar"></div>

          <div class="p-6">
            <div class="flex items-start justify-between mb-4">
              <div class="flex-1 min-w-0">
                <h3 class="text-xl font-bold text-white truncate mb-2"><%= code.name %></h3>
              </div>
              <div class="flex-shrink-0 ml-2">
                <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent/20 text-accent rounded-lg text-lg font-bold">
                  <i class="fas fa-percentage"></i>
                  <%= code.discountPercentage %>%
                </span>
              </div>
            </div>

            <div class="space-y-3 mb-4">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-key text-accent text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-text-secondary mb-0.5">Code</p>
                  <p class="text-sm font-semibold text-white truncate"><%= code.name %></p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-sync-alt text-accent text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-text-secondary mb-0.5">Usage</p>
                  <p class="text-sm font-semibold <%= fullyUsed ? 'text-red-400' : (almostUsed ? 'text-yellow-400' : 'text-white') %>">
                    <%= code.uses %> / <% if (code.maxUses !== null) { %><%= code.maxUses %><% } else { %><span class="text-green-400">∞</span><% } %>
                    <% if (fullyUsed) { %>
                    <span class="text-xs text-red-400">(Fully used)</span>
                    <% } else if (almostUsed) { %>
                    <span class="text-xs text-yellow-400">(Almost full)</span>
                    <% } %>
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="far fa-calendar-alt text-accent text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-text-secondary mb-0.5">Expiration</p>
                  <p class="text-sm font-semibold <%= isExpired ? 'text-red-400' : (expiresSoon ? 'text-yellow-400' : 'text-white') %>">
                    <% if (code.expiresAt) { %>
                    <%= code.expiresAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                    <% if (isExpired) { %>
                    <span class="text-xs text-red-400">(Expired)</span>
                    <% } else if (expiresSoon) { %>
                    <span class="text-xs text-yellow-400">(Soon)</span>
                    <% } %>
                    <% } else { %>
                    <span class="text-green-400">Never expires</span>
                    <% } %>
                  </p>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-2 pt-4 border-t border-white/10">
              <a href="/staff/discount-codes/edit/<%= code._id %>" class="flex items-center justify-center p-3 bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 rounded-lg transition-all duration-300 hover-lift">
                <i class="fas fa-edit mr-2"></i>
                <span class="font-semibold">Edit</span>
              </a>

              <form action="/staff/discount-codes/delete/<%= code._id %>" method="POST" class="inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="w-full flex items-center justify-center p-3 bg-red-500/20 hover:bg-red-500/30 text-red-400 rounded-lg transition-all duration-300 hover-lift" onclick="return confirm('Are you sure you want to delete this discount code? This action cannot be undone.');">
                  <i class="fas fa-trash mr-2"></i>
                  <span class="font-semibold">Delete</span>
                </button>
              </form>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });
  </script>
</body>

</html>