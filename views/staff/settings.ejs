                      <label class="block text-sm font-medium text-white mb-2">Webhook URL (Optional)</label>
                      <input class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2 compact-input focus:border-accent focus:outline-none transition-colors text-sm font-mono" type="text" name="vietqrWebhookUrl" value="<%= settings.paymentMethods?.vietqr?.webhookUrl || '' %>" placeholder="https://your-bank-provider/webhook">
                    </div>

                    <div class="bg-blue-500/10 border border-blue-500/30 rounded-lg p-3">
                      <p class="text-xs text-blue-300">
                        <i class="fas fa-info-circle mr-1"></i>
                        QR được tạo qua <span class="font-semibold">img.vietqr.io</span> (không cần API key). Lấy SePay Token tại <span class="font-semibold">my.sepay.vn → API</span> để bật tự động xác nhận.
                      </p>
                    </div>
                  </div>
                </div>

                <div class="bg-green-500/10 border border-green-500/30 rounded-lg p-4">
                  <p class="text-sm text-green-300">
                    <i class="fas fa-lock mr-2"></i>
                    All payment credentials are encrypted with AES-256 before storage
                  </p>
                </div>
              </div>
            </section>

            <section id="seo" class="glass-effect rounded-xl p-6 mb-6 settings-section" data-aos="fade-up">
              <div class="flex items-center gap-3 mb-6 pb-4 border-b border-white/10">
                <div class="w-10 h-10 bg-accent/20 rounded-lg flex items-center justify-center">
                  <i class="fas fa-search text-accent"></i>
                </div>
                <div>
                  <h2 class="text-xl font-bold text-white">SEO Settings</h2>
                  <p class="text-text-secondary text-sm">Search engine optimization</p>
                </div>
              </div>

              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-white mb-2">SEO Title</label>
                  <input class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2 compact-input focus:border-accent focus:outline-none transition-colors text-sm" type="text" name="seoTitle" value="<%= settings.seoTitle %>" required>
                </div>

                <div>
                  <label class="block text-sm font-medium text-white mb-2">SEO Description</label>
                  <textarea class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2 focus:border-accent focus:outline-none transition-colors resize-none text-sm" name="seoDescription" rows="3" required><%= settings.seoDescription %></textarea>
                </div>

                <div>
                  <label class="block text-sm font-medium text-white mb-2">SEO Keywords</label>
                  <input class="w-full bg-dark-lighter text-white border border-white/20 rounded-lg px-3 py-2 compact-input focus:border-accent focus:outline-none transition-colors text-sm" type="text" name="seoTags" value="<%= settings.seoTags %>" placeholder="keyword1, keyword2, keyword3" required>
                </div>
              </div>
            </section>

            <div class="sticky bottom-6 z-10" data-aos="fade-up">
              <button type="submit" class="w-full bg-accent hover:bg-accent/90 text-white px-6 py-3 rounded-xl font-semibold transition-all duration-300 flex items-center justify-center gap-3 shadow-2xl">
                <i class="fas fa-save"></i>
                <span>Save All Settings</span>
              </button>
            </div>
          </form>
        </main>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    // Show saved toast
    (function() {
      const params = new URLSearchParams(window.location.search);
      if (params.get('saved') === 'true') {
        const toast = document.createElement('div');
        toast.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Settings saved successfully!';
        toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;background:#22c55e;color:#fff;padding:14px 24px;border-radius:12px;font-weight:600;font-size:14px;box-shadow:0 4px 20px rgba(34,197,94,0.4);animation:slideIn .3s ease;';
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.opacity = '0'; toast.style.transition = 'opacity .3s'; setTimeout(() => toast.remove(), 300); }, 3000);
        window.history.replaceState({}, '', window.location.pathname);
      }
    })();

    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });

    document.querySelectorAll('.nav-item').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href').substring(1);
        const target = document.getElementById(targetId);

        if (target) {
          const offset = 100;
          const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });

    const sections = document.querySelectorAll('.settings-section');
    const navItems = document.querySelectorAll('.nav-item');

    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;
        if (window.pageYOffset >= (sectionTop - 150)) {
          current = section.getAttribute('id');
        }
      });

      navItems.forEach(item => {
        item.classList.remove('active');
        if (item.getAttribute('href') === `#${current}`) {
          item.classList.add('active');
        }
      });
    });

    const colorPicker = document.getElementById('colorPicker');
    const colorValue = document.getElementById('colorValue');
    colorPicker.addEventListener('input', () => {
      colorValue.textContent = colorPicker.value.toUpperCase();
    });

    const fileInputs = [{
        input: 'logoInput',
        display: 'logoFileName'
      },
      {
        input: 'faviconInput',
        display: 'faviconFileName'
      }
    ];

    fileInputs.forEach(({
      input,
      display
    }) => {
      document.getElementById(input).addEventListener('change', function() {
        const fileName = this.files.length > 0 ? this.files[0].name : display.replace('FileName', '');
        document.getElementById(display).textContent = fileName;
      });
    });

    const addCategoryButton = document.getElementById('addCategoryButton');
    const categoryList = document.getElementById('categoryList');
    const categoryNameInput = document.getElementById('categoryName');
    const categoryUrlInput = document.getElementById('categoryUrl');

    function updateCategoriesInput() {
      const categories = [];
      categoryList.querySelectorAll('.bg-dark-lighter').forEach(item => {
        const inputs = item.querySelectorAll('input[type="text"]');
        categories.push({
          name: inputs[0].value,
          url: inputs[1].value
        });
      });

      const existingInput = document.querySelector('input[name="categories"]');
      if (existingInput) existingInput.remove();

      const categoriesInput = document.createElement('input');
      categoriesInput.type = 'hidden';
      categoriesInput.name = 'categories';
      categoriesInput.value = JSON.stringify(categories);
      document.querySelector('form').appendChild(categoriesInput);
    }

    addCategoryButton.addEventListener('click', () => {
      const name = categoryNameInput.value.trim();
      const url = categoryUrlInput.value.trim();

      if (name && url) {
        const exists = Array.from(categoryList.querySelectorAll('input[type="text"]')).some(input =>
          input.value === name || input.value === url
        );

        if (!exists) {
          const categoryItem = document.createElement('div');
          categoryItem.className = 'flex flex-col sm:flex-row gap-2 items-stretch sm:items-center bg-dark-lighter rounded-lg p-2 border border-white/10';
          categoryItem.innerHTML = `
                <input class="flex-1 bg-dark-card text-white border-0 rounded px-3 py-1.5 text-sm" type="text" value="${name}" readonly>
                <input class="flex-1 bg-dark-card text-white border-0 rounded px-3 py-1.5 text-sm" type="text" value="${url}" readonly>
                <button type="button" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded transition-all delete-category-button w-full sm:w-auto">
                    <i class="fas fa-trash text-sm"></i>
                </button>
            `;

          categoryList.appendChild(categoryItem);
          categoryNameInput.value = '';
          categoryUrlInput.value = '';
          updateCategoriesInput();
        }
      }
    });

    categoryList.addEventListener('click', (e) => {
      if (e.target.closest('.delete-category-button')) {
        e.target.closest('.bg-dark-lighter').remove();
        updateCategoriesInput();
      }
    });

    updateCategoriesInput();


    document.addEventListener('DOMContentLoaded', function() {
      const emailEnabled = document.getElementById('emailEnabled');
      const emailConfigSection = document.getElementById('emailConfigSection');
      const emailProvider = document.getElementById('emailProvider');
      const sendgridSettings = document.getElementById('sendgridSettings');
      const smtpSettings = document.getElementById('smtpSettings');

      if (emailEnabled && emailConfigSection) {
        emailEnabled.addEventListener('change', function() {
          if (this.checked) {
            emailConfigSection.classList.remove('hidden');
          } else {
            emailConfigSection.classList.add('hidden');
          }
        });
      }

      if (emailProvider && sendgridSettings && smtpSettings) {
        emailProvider.addEventListener('change', function() {
          if (this.value === 'sendgrid') {
            sendgridSettings.classList.remove('hidden');
            smtpSettings.classList.add('hidden');
          } else {
            sendgridSettings.classList.add('hidden');
            smtpSettings.classList.remove('hidden');
          }
        });
      }

      const testEmailButton = document.getElementById('testEmailButton');
      if (testEmailButton) {
        testEmailButton.addEventListener('click', async function() {
          const button = this;
          const originalText = button.innerHTML;
          button.disabled = true;
          button.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Sending...';

          try {
            const csrfToken = document.getElementById('csrfToken').value;

            const response = await fetch('/staff/test-email', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'CSRF-Token': csrfToken
              },
              body: JSON.stringify({
                enabled: document.getElementById('emailEnabled')?.checked || false,
                fromEmail: document.querySelector('[name="emailFromAddress"]')?.value || '',
                provider: document.querySelector('[name="emailProvider"]')?.value || 'smtp',
                sendGridToken: document.querySelector('[name="emailSendGridToken"]')?.value || '',
                smtpHost: document.querySelector('[name="emailSmtpHost"]')?.value || '',
                smtpPort: document.querySelector('[name="emailSmtpPort"]')?.value || '587',
                smtpUser: document.querySelector('[name="emailSmtpUser"]')?.value || '',
                smtpPassword: document.querySelector('[name="emailSmtpPassword"]')?.value || '',
                smtpSecure: document.querySelector('[name="emailSmtpSecure"]')?.checked || false
              })
            });

            const data = await response.json();

            if (data.success) {
              alert('✅ Test email sent successfully! Check your inbox.');
            } else {
              alert('❌ Failed to send test email: ' + (data.error || 'Unknown error'));
            }
          } catch (error) {
            alert('❌ Error sending test email: ' + error.message);
          } finally {
            button.disabled = false;
            button.innerHTML = originalText;
          }
        });
      }
    });

    const paymentToggles = [{
        checkbox: 'paypalEnabled',
        config: 'paypalConfig'
      },
      {
        checkbox: 'stripeEnabled',
        config: 'stripeConfig'
      },
      {
        checkbox: 'coinbaseEnabled',
        config: 'coinbaseConfig'
      },
      {
        checkbox: 'vietqrEnabled',
        config: 'vietqrConfig'
      }
    ];

    paymentToggles.forEach(({
      checkbox,
      config
    }) => {
      const toggle = document.getElementById(checkbox);
      const configSection = document.getElementById(config);

      if (toggle && configSection) {
        toggle.addEventListener('change', function() {
          if (this.checked) {
            configSection.classList.remove('hidden');
          } else {
            configSection.classList.add('hidden');
          }
        });
      }
    });

    const paypalAccountType = document.getElementById('paypalAccountType');
    const paypalBusinessFields = document.getElementById('paypalBusinessFields');
    const paypalPersonalFields = document.getElementById('paypalPersonalFields');
    const paypalModeField = document.getElementById('paypalModeField');

    if (paypalAccountType && paypalBusinessFields && paypalPersonalFields && paypalModeField) {
      paypalAccountType.addEventListener('change', function() {
        if (this.value === 'personal') {
          paypalBusinessFields.classList.add('hidden');
          paypalPersonalFields.classList.remove('hidden');
          paypalModeField.classList.add('hidden');
        } else {
          paypalBusinessFields.classList.remove('hidden');
          paypalPersonalFields.classList.add('hidden');
          paypalModeField.classList.remove('hidden');
        }
      });
    }
  </script>
</body>

</html>