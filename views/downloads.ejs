<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - Downloads</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/markdown-it/dist/markdown-it.min.js"></script>

  <meta property="og:title" content="<%= product.name %> Download | <%= settings.storeName %>" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= settings.baseURL %>" />
  <meta property="og:image" content="<%= settings.logoPath %>" />
  <meta property="og:description" content="Download and view products" />
  <meta name="theme-color" content="<%= settings.accentColor %>">
  <meta property="og:site_name" content="<%= settings.storeName %>" />
  <meta property="og:locale" content="en_US" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 4s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .particle {
      position: absolute;
      background: var(--accent-color);
      border-radius: 50%;
      pointer-events: none;
      animation: float 6s ease-in-out infinite;
    }

    .particle:nth-child(1) {
      top: 15%;
      left: 10%;
      width: 3px;
      height: 3px;
      animation-delay: 0s;
      opacity: 0.4;
    }

    .particle:nth-child(2) {
      top: 65%;
      left: 15%;
      width: 2px;
      height: 2px;
      animation-delay: 2s;
      opacity: 0.3;
    }

    .particle:nth-child(3) {
      top: 35%;
      right: 12%;
      width: 4px;
      height: 4px;
      animation-delay: 4s;
      opacity: 0.5;
    }

    .particle:nth-child(4) {
      bottom: 25%;
      left: 18%;
      width: 2px;
      height: 2px;
      animation-delay: 1s;
      opacity: 0.3;
    }

    .particle:nth-child(5) {
      bottom: 55%;
      right: 20%;
      width: 3px;
      height: 3px;
      animation-delay: 3s;
      opacity: 0.4;
    }

    .markdown-body {
      font-size: 1rem;
      line-height: 1.6;
      color: #ffffff;
    }

    .markdown-body h1 {
      font-size: 2.5rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .markdown-body h2 {
      font-size: 2rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .markdown-body h3 {
      font-size: 1.75rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .markdown-body h4 {
      font-size: 1.5rem;
      font-weight: bold;
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .markdown-body p {
      font-size: 1rem;
      margin-bottom: 1rem;
      color: #ffffff;
    }

    .markdown-body a {
      color: var(--accent-color);
      text-decoration: none;
    }

    .markdown-body a:hover {
      text-decoration: underline;
    }

    .markdown-body ul,
    .markdown-body ol {
      padding-left: 20px;
      margin-bottom: 1rem;
      list-style-type: disc;
    }

    .markdown-body strong,
    .markdown-body b {
      font-weight: bold;
      color: var(--accent-color);
    }

    .markdown-body code {
      background-color: #161b22;
      padding: 2px 4px;
      border-radius: 4px;
      font-family: monospace;
    }

    .markdown-body pre {
      background-color: #161b22;
      padding: 10px;
      border-radius: 8px;
      overflow-x: auto;
      margin-bottom: 1rem;
    }

    .markdown-body blockquote {
      padding: 10px 20px;
      margin: 0 0 20px;
      background-color: #161b22;
      border-left: 5px solid var(--accent-color);
    }

    .markdown-body table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1rem;
    }

    .markdown-body th,
    .markdown-body td {
      padding: 10px;
      border: 1px solid #c9d1d9;
    }

    .markdown-body th {
      background-color: #161b22;
    }

    .markdown-body td {
      background-color: #0a0a0a;
    }

    .markdown-body .info,
    .markdown-body .success,
    .markdown-body .warning,
    .markdown-body .danger {
      padding: 10px;
      margin-bottom: 20px;
      border-radius: 5px;
      color: #fff;
    }

    .markdown-body .info {
      background-color: #017acd;
    }

    .markdown-body .success {
      background-color: #28a745;
    }

    .markdown-body .warning {
      background-color: #d39e00;
    }

    .markdown-body .danger {
      background-color: #dc3545;
    }

    .markdown-body iframe {
      max-width: 100%;
      height: auto;
      aspect-ratio: 16/9;
      width: 100%;
      display: block;
      margin: 0 auto;
    }

    .changelog-collapsed {
      display: none;
    }

    .changelog-expanded {
      display: block;
      animation: fade-in 0.3s ease-out;
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('partials/navbar', { user, existingUser }) %>

  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden" style="
        background: linear-gradient(
            135deg,
            rgba(var(--accent-rgb), 0.25) 0%,
            rgba(0, 0, 0, 0.85) 30%,
            rgba(0, 0, 0, 0.90) 70%,
            rgba(var(--accent-rgb), 0.20) 100%
        );
    ">
    <div class="absolute inset-0">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="text-center max-w-4xl mx-auto">
        <div class="space-y-6" data-aos="fade-up" data-aos-duration="1000">
          <h1 class="text-4xl lg:text-6xl font-black leading-tight text-white mb-4">
            <%= product.name %> Downloads
          </h1>
          <p class="text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto">
            Explore and download all available versions of <%= product.name %>
          </p>
          <% if (allVersionsCount > 0) { %>
          <div class="inline-flex items-center gap-2 bg-accent/20 px-4 py-2 rounded-lg">
            <i class="fas fa-code-branch text-accent"></i>
            <span class="text-white font-medium"><%= allVersionsCount %> <%= allVersionsCount === 1 ? 'Version' : 'Versions' %> Available</span>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-dark-lighter" id="download-section">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <% if (allVersionsCount === 0) { %>
        <div class="glass-effect rounded-2xl p-12 text-center hover-lift" data-aos="fade-up">
          <div class="w-24 h-24 bg-dark-card rounded-3xl flex items-center justify-center mx-auto mb-8">
            <i class="fas fa-file-download text-accent text-4xl"></i>
          </div>
          <h3 class="text-3xl font-bold text-white mb-4">No Versions Available</h3>
          <p class="text-text-secondary text-lg max-w-md mx-auto">
            There are currently no versions available for download. Check back later for updates.
          </p>
        </div>
        <% } else { %>
        <div class="space-y-8">
          <% product.versions.forEach((version, index) => { 
                            const isLatest = currentPage === 1 && index === 0;
                        %>
          <div class="glass-effect rounded-2xl p-8 hover-lift <%= isLatest ? 'border-accent/50' : '' %>" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6 pb-6 border-b border-white/10">
              <div class="flex items-center gap-4">
                <h3 class="text-2xl font-bold text-white"><%= version.version %></h3>
                <% if (isLatest) { %>
                <span class="px-3 py-1 bg-accent text-white text-sm font-semibold rounded-full uppercase tracking-wider">
                  Latest
                </span>
                <% } %>
              </div>

              <div class="flex flex-wrap items-center gap-6">
                <div class="flex items-center gap-2 text-text-secondary">
                  <i class="far fa-calendar-alt text-accent"></i>
                  <span><%= version.releaseDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                </div>

                <div class="flex items-center gap-2 bg-accent/20 px-4 py-2 rounded-lg">
                  <i class="fas fa-download text-accent"></i>
                  <span class="text-white font-medium"><%= version.downloadCount || 0 %></span>
                </div>
              </div>
            </div>

            <div class="mb-6">
              <% if (version.changelog && version.changelog.trim() !== '') { %>
              <button class="toggle-changelog flex items-center gap-3 text-accent hover:text-accent/80 font-semibold mb-4 transition-colors duration-300" data-target="changelog-<%= version._id %>" aria-expanded="true">
                <i class="fas fa-chevron-down transition-transform duration-300"></i>
                <span>Changelog</span>
              </button>

              <div class="changelog-container changelog-expanded bg-dark-card rounded-xl p-6 border border-white/10 max-h-96 overflow-y-auto" id="changelog-<%= version._id %>">
                <div class="markdown-body">
                  <%- md.render(version.changelog) %>
                </div>
              </div>
              <% } else { %>
              <div class="bg-dark-card rounded-xl p-6 border border-white/10">
                <p class="text-text-secondary">No changelog available for this version.</p>
              </div>
              <% } %>
            </div>

            <div class="flex flex-wrap gap-4">
              <a href="/downloads/<%= product.urlId %>/download/<%= version._id %>" class="bg-accent hover:bg-accent/90 text-white px-8 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift">
                <i class="fas fa-download"></i>
                <span>Download</span>
              </a>

              <% if (isOwner) { %>
              <form action="/downloads/<%= product.urlId %>/delete/<%= version._id %>" method="POST" class="inline" onsubmit="return confirmDelete('<%= version.version %>')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center gap-3 hover-lift">
                  <i class="fas fa-trash-alt"></i>
                  <span>Delete Version</span>
                </button>
              </form>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>

        <% if (totalPages > 1) { %>
        <div class="flex justify-center mt-12" data-aos="fade-up">
          <nav class="glass-effect rounded-xl overflow-hidden inline-flex">
            <% if (currentPage > 1) { %>
            <a href="/downloads/<%= product.urlId %>?page=<%= currentPage - 1 %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300 border-r border-white/10">
              <i class="fas fa-chevron-left"></i>
            </a>
            <% } else { %>
            <span class="px-4 py-3 bg-dark-card text-text-muted cursor-not-allowed border-r border-white/10">
              <i class="fas fa-chevron-left"></i>
            </span>
            <% } %>

            <% 
                                    let startPage = Math.max(1, currentPage - 2);
                                    let endPage = Math.min(totalPages, currentPage + 2);
                                    
                                    if (startPage > 1) { 
                                %>
            <a href="/downloads/<%= product.urlId %>?page=1" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300 border-r border-white/10">
              1
            </a>

            <% if (startPage > 2) { %>
            <span class="px-4 py-3 bg-dark-card text-text-muted border-r border-white/10">...</span>
            <% } %>
            <% } %>

            <% for (let i = startPage; i <= endPage; i++) { %>
            <a href="/downloads/<%= product.urlId %>?page=<%= i %>" class="px-4 py-3 <%= currentPage === i ? 'bg-accent text-white' : 'bg-dark-card hover:bg-accent text-text-secondary hover:text-white' %> transition-all duration-300 border-r border-white/10 font-semibold">
              <%= i %>
            </a>
            <% } %>

            <% if (endPage < totalPages) { %>
            <% if (endPage < totalPages - 1) { %>
            <span class="px-4 py-3 bg-dark-card text-text-muted border-r border-white/10">...</span>
            <% } %>

            <a href="/downloads/<%= product.urlId %>?page=<%= totalPages %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300 border-r border-white/10">
              <%= totalPages %>
            </a>
            <% } %>

            <% if (currentPage < totalPages) { %>
            <a href="/downloads/<%= product.urlId %>?page=<%= currentPage + 1 %>" class="px-4 py-3 bg-dark-card hover:bg-accent text-text-secondary hover:text-white transition-all duration-300">
              <i class="fas fa-chevron-right"></i>
            </a>
            <% } else { %>
            <span class="px-4 py-3 bg-dark-card text-text-muted cursor-not-allowed">
              <i class="fas fa-chevron-right"></i>
            </span>
            <% } %>
          </nav>
        </div>
        <% } %>
        <% } %>
      </div>
    </div>
  </section>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });

    function confirmDelete(versionName) {
      return confirm(`Are you sure you want to delete version "${versionName}"?\n\nThis action cannot be undone and will permanently remove this version.`);
    }

    document.addEventListener('DOMContentLoaded', function() {
      const toggleButtons = document.querySelectorAll('.toggle-changelog');
      toggleButtons.forEach(button => {
        button.addEventListener('click', function() {
          const targetId = this.getAttribute('data-target');
          const targetElement = document.getElementById(targetId);
          const chevron = this.querySelector('i');

          if (this.getAttribute('aria-expanded') === 'true') {
            targetElement.classList.remove('changelog-expanded');
            targetElement.classList.add('changelog-collapsed');
            this.setAttribute('aria-expanded', 'false');
            chevron.style.transform = 'rotate(-90deg)';
          } else {
            targetElement.classList.remove('changelog-collapsed');
            targetElement.classList.add('changelog-expanded');
            this.setAttribute('aria-expanded', 'true');
            chevron.style.transform = 'rotate(0deg)';
          }
        });
      });
    });
  </script>

  <%- include('partials/footer') %>
</body>

</html>