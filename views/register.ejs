<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tạo Tài Khoản - <%= settings.storeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

  <meta property="og:title" content="Tạo Tài Khoản | <%= settings.storeName %>" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="<%= config.baseURL %>/register" />
  <meta property="og:image" content="<%= settings.logoPath %>" />
  <meta property="og:description" content="Tạo tài khoản trên <%= settings.storeName %>" />
  <meta name="theme-color" content="<%= settings.accentColor %>">
  <meta property="og:site_name" content="<%= settings.storeName %>" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'fade-in': 'fade-in 0.3s ease-out forwards',
          },
          keyframes: {
            float: {
              '0%, 100%': {
                transform: 'translateY(0px)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .particle {
      position: absolute;
      background: var(--accent-color);
      border-radius: 50%;
      pointer-events: none;
      animation: float 6s ease-in-out infinite;
    }

    .particle:nth-child(1) {
      top: 15%;
      left: 10%;
      width: 3px;
      height: 3px;
      animation-delay: 0s;
      opacity: 0.4;
    }

    .particle:nth-child(2) {
      top: 65%;
      left: 15%;
      width: 2px;
      height: 2px;
      animation-delay: 2s;
      opacity: 0.3;
    }

    .particle:nth-child(3) {
      top: 35%;
      right: 12%;
      width: 4px;
      height: 4px;
      animation-delay: 4s;
      opacity: 0.5;
    }

    .particle:nth-child(4) {
      bottom: 25%;
      left: 18%;
      width: 2px;
      height: 2px;
      animation-delay: 1s;
      opacity: 0.3;
    }

    .particle:nth-child(5) {
      bottom: 55%;
      right: 20%;
      width: 3px;
      height: 3px;
      animation-delay: 3s;
      opacity: 0.4;
    }

    .password-strength-bar {
      height: 4px;
      background: #2a2a2a;
      border-radius: 2px;
      overflow: hidden;
      margin-top: 8px;
    }

    .password-strength-fill {
      height: 100%;
      width: 0%;
      transition: all 0.3s ease;
      border-radius: 2px;
    }

    .strength-weak {
      width: 33%;
      background: #ef4444;
    }

    .strength-medium {
      width: 66%;
      background: #f59e0b;
    }

    .strength-strong {
      width: 100%;
      background: #10b981;
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('partials/navbar', { user: user || null, existingUser: existingUser || null }) %>

  <section class="relative min-h-screen flex items-center justify-center overflow-hidden py-20" style="
        background: linear-gradient(
            135deg,
            rgba(var(--accent-rgb), 0.25) 0%,
            rgba(0, 0, 0, 0.85) 30%,
            rgba(0, 0, 0, 0.90) 70%,
            rgba(var(--accent-rgb), 0.20) 100%
        );
    ">
    <div class="absolute inset-0">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-md mx-auto">
        <div class="text-center mb-8" data-aos="fade-up">
          <img src="<%= settings.logoPath %>" alt="Logo" class="w-20 h-20 rounded-xl mx-auto mb-6 shadow-2xl ring-2 ring-accent/50">
          <h1 class="text-4xl font-black text-white mb-2">Tạo Tài Khoản</h1>
          <p class="text-text-secondary">Tham gia <%= settings.storeName %> ngay hôm nay</p>
        </div>

        <div class="glass-effect rounded-2xl p-8 hover-lift" data-aos="fade-up" data-aos-delay="100">

          <% if (authConfig.Discord && authConfig.Discord.enabled && (authConfig.mode === 'discord' || authConfig.mode === 'both')) { %>
          <a href="/auth/discord" class="w-full bg-[#5865F2] hover:bg-[#4752C4] text-white px-6 py-4 rounded-xl font-semibold transition-all duration-300 flex items-center justify-center gap-3 hover-lift mb-6 group">
            <i class="fab fa-discord text-2xl group-hover:scale-110 transition-transform"></i>
            <span>Tiếp Tục Với Discord</span>
          </a>

          <% if (authConfig.Local && authConfig.Local.enabled && authConfig.mode === 'both') { %>
          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-white/10"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-4 bg-dark-card text-text-muted">Hoặc tiếp tục với email</span>
            </div>
          </div>
          <% } %>
          <% } %>

          <% if (authConfig.Local && authConfig.Local.enabled && (authConfig.mode === 'local' || authConfig.mode === 'both')) { %>
          <% if (typeof success !== 'undefined' && success) { %>
          <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 mb-6 animate-fade-in">
            <div class="flex items-start gap-3 mb-4">
              <i class="fas fa-check-circle text-green-400 mt-1"></i>
              <div class="flex-1">
                <p class="text-green-400 text-sm font-semibold mb-1">Đăng Ký Thành Công!</p>
                <p class="text-green-300 text-sm"><%= success %></p>
              </div>
            </div>

            <button id="resendButton" onclick="resendVerification()" class="w-full bg-accent/20 hover:bg-accent/30 text-accent border border-accent/50 px-4 py-3 rounded-lg font-semibold transition-all duration-300 flex items-center justify-center gap-2 text-sm">
              <i class="fas fa-paper-plane"></i>
              <span id="resendButtonText">Gửi Lại Email Xác Minh</span>
            </button>

            <p class="text-xs text-green-300 mt-2 text-center" id="resendStatus"></p>
          </div>
          <% } %>

          <% if (typeof error !== 'undefined' && error) { %>
          <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6 animate-fade-in">
            <div class="flex items-start gap-3">
              <i class="fas fa-exclamation-circle text-red-400 mt-1"></i>
              <div class="flex-1">
                <p class="text-red-400 text-sm"><%= error %></p>
              </div>
            </div>
          </div>
          <% } %>

          <form action="/register" method="POST" class="space-y-5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div>
              <label class="block text-white font-medium mb-2 text-sm">Tên Người Dùng</label>
              <div class="relative">
                <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-accent">
                  <i class="fas fa-user"></i>
                </div>
                <input type="text" name="username" required placeholder="Chọn tên người dùng" class="w-full bg-dark-card text-white pl-12 pr-4 py-3 rounded-xl border border-white/10 focus:border-accent focus:outline-none transition-all duration-300" value="<%= typeof username !== 'undefined' ? username : '' %>">
              </div>
            </div>

            <div>
              <label class="block text-white font-medium mb-2 text-sm">Email</label>
              <div class="relative">
                <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-accent">
                  <i class="fas fa-envelope"></i>
                </div>
                <input type="email" name="email" required placeholder="your@email.com" class="w-full bg-dark-card text-white pl-12 pr-4 py-3 rounded-xl border border-white/10 focus:border-accent focus:outline-none transition-all duration-300" value="<%= typeof email !== 'undefined' ? email : '' %>">
              </div>
            </div>

            <div>
              <label class="block text-white font-medium mb-2 text-sm">Mật Khẩu</label>
              <div class="relative">
                <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-accent">
                  <i class="fas fa-lock"></i>
                </div>
                <input type="password" id="password" name="password" required placeholder="Tối thiểu <%= authConfig.Local.minPasswordLength || 8 %> ký tự" class="w-full bg-dark-card text-white pl-12 pr-12 py-3 rounded-xl border border-white/10 focus:border-accent focus:outline-none transition-all duration-300">
                <button type="button" onclick="togglePassword('password')" class="absolute right-4 top-1/2 transform -translate-y-1/2 text-text-muted hover:text-white transition-colors">
                  <i class="fas fa-eye" id="password-toggle-icon"></i>
                </button>
              </div>
              <div class="password-strength-bar">
                <div class="password-strength-fill" id="strength-bar"></div>
              </div>
              <p class="text-xs text-text-muted mt-2" id="strength-text">Sử dụng 8+ ký tự với sự kết hợp chữ cái, số & ký hiệu</p>
            </div>

            <div>
              <label class="block text-white font-medium mb-2 text-sm">Xác Nhận Mật Khẩu</label>
              <div class="relative">
                <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-accent">
                  <i class="fas fa-lock"></i>
                </div>
                <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Nhập lại mật khẩu" class="w-full bg-dark-card text-white pl-12 pr-12 py-3 rounded-xl border border-white/10 focus:border-accent focus:outline-none transition-all duration-300">
                <button type="button" onclick="togglePassword('confirmPassword')" class="absolute right-4 top-1/2 transform -translate-y-1/2 text-text-muted hover:text-white transition-colors">
                  <i class="fas fa-eye" id="confirmPassword-toggle-icon"></i>
                </button>
              </div>
            </div>

            <button type="submit" class="w-full bg-accent hover:bg-accent/90 text-white px-6 py-4 rounded-xl font-semibold transition-all duration-300 hover-lift flex items-center justify-center gap-2 mt-6">
              <i class="fas fa-user-plus"></i>
              <span>Tạo Tài Khoản</span>
            </button>
          </form>
          <% } %>

          <div class="mt-6 text-center">
            <p class="text-text-secondary text-sm">
              Đã có tài khoản?
              <a href="/login" class="text-accent hover:text-accent/80 font-semibold transition-colors">
                Đăng Nhập
              </a>
            </p>
          </div>
        </div>

        <% if (authConfig.Local && authConfig.Local.requireEmailVerification) { %>
        <div class="text-center mt-6" data-aos="fade-up" data-aos-delay="200">
          <p class="text-text-muted text-sm flex items-center justify-center gap-2">
            <i class="fas fa-info-circle text-accent"></i>
            Cần xác minh email sau khi đăng ký
          </p>
        </div>
        <% } %>
      </div>
    </div>
  </section>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 100
    });

    function togglePassword(fieldId) {
      const field = document.getElementById(fieldId);
      const icon = document.getElementById(fieldId + '-toggle-icon');

      if (field.type === 'password') {
        field.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
      } else {
        field.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
      }
    }

    const passwordField = document.getElementById('password');
    const strengthBar = document.getElementById('strength-bar');
    const strengthText = document.getElementById('strength-text');

    if (passwordField) {
      passwordField.addEventListener('input', function() {
        const password = this.value;
        let strength = 0;

        if (password.length >= 8) strength++;
        if (password.length >= 12) strength++;
        if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
        if (/\d/.test(password)) strength++;
        if (/[^a-zA-Z\d]/.test(password)) strength++;

        strengthBar.className = 'password-strength-fill';

        if (strength <= 2) {
          strengthBar.classList.add('strength-weak');
          strengthText.textContent = 'Mật khẩu yếu - thêm nhiều ký tự hơn';
          strengthText.className = 'text-xs text-red-400 mt-2';
        } else if (strength <= 4) {
          strengthBar.classList.add('strength-medium');
          strengthText.textContent = 'Độ mạnh trung bình - gần xong rồi!';
          strengthText.className = 'text-xs text-yellow-400 mt-2';
        } else {
          strengthBar.classList.add('strength-strong');
          strengthText.textContent = 'Mật khẩu mạnh!';
          strengthText.className = 'text-xs text-green-400 mt-2';
        }
      });
    }

    const confirmPasswordField = document.getElementById('confirmPassword');
    if (confirmPasswordField && passwordField) {
      confirmPasswordField.addEventListener('input', function() {
        if (this.value && this.value !== passwordField.value) {
          this.setCustomValidity('Mật khẩu không khớp');
          this.classList.add('border-red-500');
        } else {
          this.setCustomValidity('');
          this.classList.remove('border-red-500');
        }
      });

      passwordField.addEventListener('input', function() {
        if (confirmPasswordField.value) {
          confirmPasswordField.dispatchEvent(new Event('input'));
        }
      });
    }

    let resendCooldown = 0;
    let resendTimer = null;
    const resendEmail = '<%= typeof email !== "undefined" ? email : "" %>';

    function resendVerification() {
      if (resendCooldown > 0) {
        return;
      }

      const button = document.getElementById('resendButton');
      const buttonText = document.getElementById('resendButtonText');
      const statusText = document.getElementById('resendStatus');

      button.disabled = true;
      buttonText.textContent = 'Đang gửi...';
      statusText.textContent = '';

      fetch('/api/resend-verification', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'CSRF-Token': '<%= csrfToken %>'
          },
          body: JSON.stringify({
            email: resendEmail
          })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            statusText.textContent = '✓ Email đã được gửi thành công!';
            statusText.className = 'text-xs text-green-400 mt-2 text-center';

            resendCooldown = 60;
            updateCooldownButton();
          } else {
            statusText.textContent = data.message || 'Gửi email thất bại';
            statusText.className = 'text-xs text-red-400 mt-2 text-center';
            button.disabled = false;
            buttonText.textContent = 'Gửi Lại Email Xác Minh';
          }
        })
        .catch(error => {
          console.error('Error:', error);
          statusText.textContent = 'Đã xảy ra lỗi. Vui lòng thử lại.';
          statusText.className = 'text-xs text-red-400 mt-2 text-center';
          button.disabled = false;
          buttonText.textContent = 'Gửi Lại Email Xác Minh';
        });
    }

    function updateCooldownButton() {
      const button = document.getElementById('resendButton');
      const buttonText = document.getElementById('resendButtonText');

      if (resendCooldown > 0) {
        button.disabled = true;
        button.classList.add('opacity-50', 'cursor-not-allowed');
        buttonText.textContent = `Chờ ${resendCooldown}s trước khi gửi lại`;

        resendTimer = setTimeout(() => {
          resendCooldown--;
          updateCooldownButton();
        }, 1000);
      } else {
        button.disabled = false;
        button.classList.remove('opacity-50', 'cursor-not-allowed');
        buttonText.textContent = 'Gửi Lại Email Xác Minh';
        if (resendTimer) {
          clearTimeout(resendTimer);
        }
      }
    }
  </script>

  <%- include('partials/footer') %>
</body>

</html>