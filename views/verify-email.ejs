<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verification - <%= settings.storeName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

    <meta property="og:title" content="Email Verification | <%= settings.storeName %>" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="<%= config.baseURL %>/verify-email" />
    <meta property="og:image" content="<%= settings.logoPath %>" />
    <meta name="theme-color" content="<%= settings.accentColor %>">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'dark': '#0a0a0a',
                        'dark-lighter': '#111111',
                        'dark-card': '#1a1a1a',
                        'dark-border': '#2a2a2a',
                        'text-primary': '#ffffff',
                        'text-secondary': '#a1a1aa',
                        'text-muted': '#71717a'
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'fade-in': 'fade-in 0.3s ease-out forwards',
                        'spin-slow': 'spin 3s linear infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0px)' },
                            '50%': { transform: 'translateY(-10px)' }
                        },
                        'fade-in': {
                            '0%': { opacity: '0', transform: 'translateY(10px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' }
                        }
                    }
                }
            }
        }
    </script>

    <style>
        :root {
            --accent-color: <%= settings.accentColor %>;
            --accent-rgb: <%= accentColorRgb %>;
        }
        
        body {
            background: #0a0a0a;
            color: #ffffff;
        }

        .glass-effect {
            background: rgba(26, 26, 26, 0.8);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(var(--accent-rgb), 0.3);
            box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
        }

        .text-accent {
            color: var(--accent-color);
        }

        .bg-accent {
            background-color: var(--accent-color);
        }

        .particle {
            position: absolute;
            background: var(--accent-color);
            border-radius: 50%;
            pointer-events: none;
            animation: float 6s ease-in-out infinite;
        }

        .particle:nth-child(1) { top: 15%; left: 10%; width: 3px; height: 3px; animation-delay: 0s; opacity: 0.4; }
        .particle:nth-child(2) { top: 65%; left: 15%; width: 2px; height: 2px; animation-delay: 2s; opacity: 0.3; }
        .particle:nth-child(3) { top: 35%; right: 12%; width: 4px; height: 4px; animation-delay: 4s; opacity: 0.5; }
        .particle:nth-child(4) { bottom: 25%; left: 18%; width: 2px; height: 2px; animation-delay: 1s; opacity: 0.3; }
        .particle:nth-child(5) { bottom: 55%; right: 20%; width: 3px; height: 3px; animation-delay: 3s; opacity: 0.4; }
    </style>
</head>

<body class="bg-dark text-white">

    <section class="relative min-h-screen flex items-center justify-center overflow-hidden py-20" style="
        background: linear-gradient(
            135deg,
            rgba(var(--accent-rgb), 0.25) 0%,
            rgba(0, 0, 0, 0.85) 30%,
            rgba(0, 0, 0, 0.90) 70%,
            rgba(var(--accent-rgb), 0.20) 100%
        );
    ">
        <div class="absolute inset-0">
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
        </div>

        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-md mx-auto">
                <% if (success) { %>
                    <div class="text-center mb-8" data-aos="fade-up">
                        <div class="w-24 h-24 bg-green-500/20 rounded-full flex items-center justify-center mx-auto mb-6 ring-4 ring-green-500/30">
                            <i class="fas fa-check text-green-400 text-4xl"></i>
                        </div>
                        <h1 class="text-4xl font-black text-white mb-3">Email Verified!</h1>
                        <p class="text-text-secondary text-lg">Your account has been successfully verified</p>
                    </div>

                    <div class="glass-effect rounded-2xl p-8" data-aos="fade-up" data-aos-delay="100">
                        <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 mb-6">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-check-circle text-green-400 mt-1"></i>
                                <div class="flex-1">
                                    <p class="text-green-400 text-sm font-semibold mb-1">Verification Complete</p>
                                    <p class="text-green-300 text-sm">You can now access all features of your account.</p>
                                </div>
                            </div>
                        </div>

                        <a href="/login" class="w-full bg-accent hover:bg-accent/90 text-white px-6 py-4 rounded-xl font-semibold transition-all duration-300 flex items-center justify-center gap-2">
                            <i class="fas fa-sign-in-alt"></i>
                            <span>Continue to Login</span>
                        </a>
                    </div>
                <% } else if (error) { %>
                    <div class="text-center mb-8" data-aos="fade-up">
                        <div class="w-24 h-24 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6 ring-4 ring-red-500/30">
                            <i class="fas fa-times text-red-400 text-4xl"></i>
                        </div>
                        <h1 class="text-4xl font-black text-white mb-3">Verification Failed</h1>
                        <p class="text-text-secondary text-lg">We couldn't verify your email address</p>
                    </div>

                    <div class="glass-effect rounded-2xl p-8" data-aos="fade-up" data-aos-delay="100">
                        <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-exclamation-circle text-red-400 mt-1"></i>
                                <div class="flex-1">
                                    <p class="text-red-400 text-sm"><%= error %></p>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-3">
                            
                            <a href="/login" class="w-full bg-dark-card hover:bg-dark-border text-white border border-white/10 px-6 py-3 rounded-xl font-semibold transition-all duration-300 flex items-center justify-center gap-2">
                                <i class="fas fa-arrow-left"></i>
                                <span>Back to Login</span>
                            </a>
                        </div>
                    </div>
                <% } else { %>
                    <div class="text-center mb-8" data-aos="fade-up">
                        <div class="w-24 h-24 bg-accent/20 rounded-full flex items-center justify-center mx-auto mb-6 ring-4 ring-accent/30">
                            <i class="fas fa-spinner text-accent text-4xl animate-spin-slow"></i>
                        </div>
                        <h1 class="text-4xl font-black text-white mb-3">Verifying Email...</h1>
                        <p class="text-text-secondary text-lg">Please wait while we verify your email address</p>
                    </div>

                    <div class="glass-effect rounded-2xl p-8" data-aos="fade-up" data-aos-delay="100">
                        <div class="bg-accent/10 border border-accent/30 rounded-xl p-4">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-info-circle text-accent mt-1"></i>
                                <div class="flex-1">
                                    <p class="text-accent text-sm">This should only take a moment...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>

                <div class="text-center mt-6" data-aos="fade-up" data-aos-delay="200">
                    <p class="text-text-muted text-sm">
                        Need help? 
                        <a href="<%= settings.discordInviteLink %>" class="text-accent hover:text-accent/80 font-semibold transition-colors">
                            Contact Support
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <script>
        AOS.init({
            duration: 400,
            easing: 'ease-out',
            once: true,
            offset: 100
        });
    </script>

    <%- include('partials/footer') %>
</body>

</html>