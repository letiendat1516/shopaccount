<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice #<%= payment.ID %> - <%= settings.storeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="icon" href="<%= settings.faviconPath %>" type="image/x-icon">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'dark': '#0a0a0a',
            'dark-lighter': '#111111',
            'dark-card': '#1a1a1a',
            'dark-border': '#2a2a2a',
            'text-primary': '#ffffff',
            'text-secondary': '#a1a1aa',
            'text-muted': '#71717a'
          },
          animation: {
            'confetti': 'confetti 3s ease-out forwards',
            'bounce-gentle': 'bounce-gentle 2s ease-in-out infinite',
            'fade-in': 'fade-in 0.5s ease-out forwards',
            'slide-up': 'slide-up 0.6s ease-out forwards',
          },
          keyframes: {
            'bounce-gentle': {
              '0%, 100%': {
                transform: 'translateY(0)'
              },
              '50%': {
                transform: 'translateY(-10px)'
              }
            },
            'fade-in': {
              '0%': {
                opacity: '0'
              },
              '100%': {
                opacity: '1'
              }
            },
            'slide-up': {
              '0%': {
                transform: 'translateY(20px)',
                opacity: '0'
              },
              '100%': {
                transform: 'translateY(0)',
                opacity: '1'
              }
            }
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --accent-color: <%=settings.accentColor %>;
      --accent-rgb: <%=accentColorRgb %>;
    }

    body {
      background: #0a0a0a;
      color: #ffffff;
    }

    .glass-effect {
      background: rgba(26, 26, 26, 0.8);
      backdrop-filter: blur(25px);
      border: 1px solid rgba(var(--accent-rgb), 0.3);
      box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.1);
    }

    .hover-lift {
      transition: all 0.3s ease;
    }

    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    .text-accent {
      color: var(--accent-color);
    }

    .bg-accent {
      background-color: var(--accent-color);
    }

    .border-accent {
      border-color: var(--accent-color);
    }

    .success-glow {
      box-shadow: 0 0 30px rgba(34, 197, 94, 0.3);
    }

    @keyframes shimmer {
      0% {
        background-position: -1000px 0;
      }

      100% {
        background-position: 1000px 0;
      }
    }

    .shimmer {
      background: linear-gradient(90deg, transparent, rgba(var(--accent-rgb), 0.2), transparent);
      background-size: 1000px 100%;
      animation: shimmer 2s infinite;
    }

    .bundle-badge {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }
  </style>
</head>

<body class="bg-dark text-white">
  <%- include('partials/navbar', { user, existingUser }) %>

  <div class="min-h-screen bg-dark-lighter py-12">
    <div class="container mx-auto px-6 max-w-5xl">
      <a href="/profile/<%= user.id %>#invoices" class="inline-flex items-center gap-2 px-4 py-2 bg-dark-card hover:bg-dark-border text-text-secondary hover:text-white border border-white/20 hover:border-accent/50 rounded-lg transition-all duration-300 hover-lift mb-8" data-aos="fade-right">
        <i class="fas fa-arrow-left"></i>
        <span class="font-medium">Back to Profile</span>
      </a>

      <div class="text-center mb-12" data-aos="fade-up">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-green-500/20 rounded-full mb-6 success-glow animate-bounce-gentle">
          <i class="fas fa-check-circle text-green-400 text-4xl"></i>
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Payment Successful!</h1>
        <p class="text-xl text-text-secondary">Thank you for your purchase. Your order has been completed.</p>
      </div>

      <div class="glass-effect rounded-3xl overflow-hidden mb-8" data-aos="fade-up" data-aos-delay="100">
        <div class="bg-gradient-to-r from-green-600 to-green-500 p-6 relative overflow-hidden">
          <div class="absolute inset-0 shimmer"></div>
          <div class="relative z-10 flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-white/20 rounded-xl flex items-center justify-center">
                <i class="fas fa-receipt text-white text-xl"></i>
              </div>
              <div>
                <div class="text-white/80 text-sm font-medium">Invoice Number</div>
                <div class="text-white text-2xl font-bold">#<%= payment.ID %></div>
              </div>
            </div>
            <div class="flex items-center gap-3 bg-white/20 px-4 py-2 rounded-xl">
              <i class="fas fa-check-circle text-white"></i>
              <span class="text-white font-bold">PAID</span>
            </div>
          </div>
        </div>

        <div class="p-8 border-b border-white/10">
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h2 class="text-2xl font-bold text-white mb-2"><%= settings.storeName %></h2>
              <div class="flex items-center gap-2 text-green-400 font-semibold">
                <i class="fas fa-check-circle"></i>
                <span>Payment Completed</span>
              </div>
            </div>
            <div class="flex items-center justify-start md:justify-end">
              <div class="bg-dark-card border border-accent/30 rounded-xl px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if (payment.paymentMethod === 'paypal') { %>
                  <i class="fab fa-paypal text-accent text-2xl"></i>
                  <% } else if (payment.paymentMethod === 'stripe') { %>
                  <i class="fab fa-stripe text-accent text-2xl"></i>
                  <% } else if (payment.paymentMethod === 'coinbase') { %>
                  <i class="fab fa-bitcoin text-accent text-2xl"></i>
                  <% } %>
                  <div>
                    <div class="text-xs text-text-muted uppercase">Paid with</div>
                    <div class="text-white font-bold"><%= payment.paymentMethod.charAt(0).toUpperCase() + payment.paymentMethod.slice(1) %></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="p-8 border-b border-white/10">
          <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
            <i class="fas fa-info-circle text-accent"></i>
            Transaction Information
          </h3>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-dark-card rounded-xl p-4">
              <div class="text-xs text-text-muted uppercase mb-1">Date & Time</div>
              <div class="text-white font-semibold">
                <%= new Date(payment.createdAt).toLocaleString('en-US', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                }) %>
              </div>
            </div>
            <div class="bg-dark-card rounded-xl p-4">
              <div class="text-xs text-text-muted uppercase mb-1">Transaction ID</div>
              <div class="text-white font-semibold break-all"><%= payment.transactionID %></div>
            </div>
            <div class="bg-dark-card rounded-xl p-4">
              <div class="text-xs text-text-muted uppercase mb-1">Payment Method</div>
              <div class="text-white font-semibold"><%= payment.paymentMethod.charAt(0).toUpperCase() + payment.paymentMethod.slice(1) %></div>
            </div>
          </div>
        </div>

        <div class="p-8 border-b border-white/10">
          <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
            <i class="fas fa-user text-accent"></i>
            Customer Details
          </h3>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-dark-card rounded-xl p-4">
              <div class="text-xs text-text-muted uppercase mb-1">Customer Name</div>
              <div class="text-white font-semibold"><%= payment.username %></div>
            </div>
            <div class="bg-dark-card rounded-xl p-4">
              <div class="text-xs text-text-muted uppercase mb-1">Email</div>
              <div class="text-white font-semibold break-all"><%= payment.email %></div>
            </div>
            <div class="bg-dark-card rounded-xl p-4">
              <div class="text-xs text-text-muted uppercase mb-1">User ID</div>
              <div class="text-white font-semibold"><%= payment.userID %></div>
            </div>
            <% if (payment.discountCode) { %>
            <div class="bg-dark-card rounded-xl p-4 border border-green-500/30">
              <div class="text-xs text-text-muted uppercase mb-1">Discount Applied</div>
              <div class="text-green-400 font-bold">
                <%= payment.discountCode %> (<%= payment.discountPercentage %>% off)
              </div>
            </div>
            <% } %>
          </div>
        </div>

        <div class="p-8">
          <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
            <i class="fas fa-shopping-bag text-accent"></i>
            Purchased Products
          </h3>

          <%
          const individualProducts = payment.products.filter(p => !p.name.includes('(from '));
          const bundleProducts = payment.products.filter(p => p.name.includes('(from '));
          
          const bundleGroups = {};
          bundleProducts.forEach(product => {
            const match = product.name.match(/\(from (.+)\)$/);
            if (match) {
              const bundleName = match[1];
              if (!bundleGroups[bundleName]) {
                bundleGroups[bundleName] = [];
              }
              bundleGroups[bundleName].push(product);
            }
          });
          %>

          <div class="space-y-4 mb-6">
            <% if (individualProducts.length > 0) { %>
            <div>
              <div class="flex items-center gap-2 mb-3">
                <i class="fas fa-box text-accent text-sm"></i>
                <h4 class="text-sm font-bold text-white uppercase tracking-wide">Individual Products</h4>
              </div>
              <div class="space-y-3">
                <% individualProducts.forEach((product) => { %>
                <div class="bg-dark-card rounded-xl p-4 hover:bg-dark-border transition-colors">
                  <div class="flex items-center justify-between gap-4 flex-wrap">
                    <div class="flex-1">
                      <div class="text-white font-bold text-lg"><%= product.name %></div>
                    </div>
                    <div class="flex items-center gap-6">
                      <div class="text-right">
                        <% if (product.salePrice) { %>
                        <div class="text-xs text-text-muted uppercase mb-1">Original</div>
                        <div class="text-text-muted line-through text-sm">
                          <%= settings.currencySymbol %><%= product.originalPrice.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                        </div>
                        <div class="text-green-400 font-bold">
                          <%= settings.currencySymbol %><%= product.salePrice.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                        </div>
                        <% } else { %>
                        <div class="text-xs text-text-muted uppercase mb-1">Original</div>
                        <div class="text-white font-bold">
                          <%= settings.currencySymbol %><%= product.originalPrice.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                        </div>
                        <% } %>
                      </div>
                      <div class="text-right">
                        <div class="text-xs text-text-muted uppercase mb-1">Paid</div>
                        <div class="text-accent font-bold text-xl">
                          <%= settings.currencySymbol %><%= product.price.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <% }); %>
              </div>
            </div>
            <% } %>

            <% if (Object.keys(bundleGroups).length > 0) { %>
            <div>
              <div class="flex items-center gap-2 mb-3">
                <i class="fas fa-box-open text-green-400 text-sm"></i>
                <h4 class="text-sm font-bold text-white uppercase tracking-wide">Bundle Purchases</h4>
              </div>
              <div class="space-y-4">
<% Object.keys(bundleGroups).forEach((bundleName) => { 
  const productsInBundle = bundleGroups[bundleName];
  const bundleOriginalTotal = productsInBundle.reduce((sum, p) => sum + p.originalPrice, 0);
  const bundleDiscountedTotal = productsInBundle.reduce((sum, p) => sum + p.price, 0);
%>
                <div class="bg-gradient-to-br from-green-500/10 to-transparent rounded-xl border-2 border-green-500/30 p-5">
                  <div class="flex items-start justify-between gap-4 mb-4">
                    <div class="flex items-center gap-3">
                      <div class="bundle-badge text-white px-3 py-1 rounded-lg text-xs font-bold shadow-lg">
                        <i class="fas fa-box-open mr-1"></i>
                        BUNDLE
                      </div>
                      <h5 class="text-white font-bold text-lg"><%= bundleName %></h5>
                    </div>
<div class="text-right">
  <div class="text-xs text-text-muted uppercase mb-1">Bundle Total</div>
  <% if (bundleOriginalTotal > bundleDiscountedTotal) { %>
  <div class="text-text-muted line-through text-sm">
    <%= settings.currencySymbol %><%= bundleOriginalTotal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
  </div>
  <% } %>
  <div class="text-green-400 font-bold text-xl">
    <%= settings.currencySymbol %><%= bundleDiscountedTotal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
  </div>
</div>
                  </div>

                  <div class="space-y-2 pl-4 border-l-2 border-green-500/30">
                    <% productsInBundle.forEach((product) => { 
                      const cleanName = product.name.replace(/\s*\(from .+\)$/, '');
                    %>
                    <div class="bg-dark-card/50 rounded-lg p-3 hover:bg-dark-card transition-colors">
                      <div class="flex items-center justify-between gap-4 flex-wrap">
                        <div class="flex items-center gap-2 flex-1">
                          <i class="fas fa-check-circle text-green-400 text-xs"></i>
                          <div class="text-white font-semibold"><%= cleanName %></div>
                        </div>
                        <div class="flex items-center gap-4">
                          <div class="text-right">
                            <% if (product.salePrice) { %>
                            <div class="text-xs text-text-muted uppercase mb-0.5">Original</div>
                            <div class="text-text-muted line-through text-xs">
                              <%= settings.currencySymbol %><%= product.originalPrice.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                            </div>
                            <div class="text-green-400 text-sm font-bold">
                              <%= settings.currencySymbol %><%= product.salePrice.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                            </div>
                            <% } else { %>
                            <div class="text-xs text-text-muted uppercase mb-0.5">Original</div>
                            <div class="text-white text-sm font-bold">
                              <%= settings.currencySymbol %><%= product.originalPrice.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                            </div>
                            <% } %>
                          </div>
                          <div class="text-right">
                            <div class="text-xs text-text-muted uppercase mb-0.5">Paid</div>
                            <div class="text-accent font-bold">
                              <%= settings.currencySymbol %><%= product.price.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    <% }); %>
                  </div>
                </div>
                <% }); %>
              </div>
            </div>
            <% } %>
          </div>

          <div class="bg-gradient-to-br from-accent/20 via-accent/10 to-transparent rounded-2xl p-6 border border-accent/40">
            <div class="space-y-3 mb-4">
              <div class="flex justify-between items-center">
                <span class="text-text-secondary">Subtotal</span>
                <span class="text-white font-semibold">
                  <%= settings.currencySymbol %><%= payment.originalSubtotal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                </span>
              </div>

              <% if (payment.discountAmount > 0) { %>
              <div class="flex justify-between items-center">
                <span class="text-text-secondary">Discount (<%= payment.discountPercentage %>%)</span>
                <span class="text-green-400 font-semibold">
                  -<%= settings.currencySymbol %><%= payment.discountAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                </span>
              </div>
              <% } %>

              <% if (payment.salesTaxAmount > 0) { %>
              <div class="flex justify-between items-center">
                <span class="text-text-secondary">Tax</span>
                <span class="text-white font-semibold">
                  <%= settings.currencySymbol %><%= payment.salesTaxAmount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                </span>
              </div>
              <% } %>
            </div>

            <div class="pt-4 border-t border-accent/40">
              <div class="flex justify-between items-center">
                <span class="text-white text-xl font-bold">Total Paid</span>
                <span class="text-accent text-3xl font-black">
                  <%= settings.currencySymbol %><%= payment.totalPaid.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                </span>
              </div>
            </div>
          </div>
        </div>

        <% if (isOwner) { %>
        <div class="p-8 bg-red-500/5 border-t border-red-500/30">
          <h3 class="text-lg font-bold text-red-400 mb-4 flex items-center gap-2">
            <i class="fas fa-lock"></i>
            Staff Only Information
          </h3>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-dark-card rounded-xl p-4 border border-red-500/20">
              <div class="text-xs text-text-muted uppercase mb-1">IP Address</div>
              <div class="text-white font-semibold font-mono text-sm"><%= payment.ipAddress || 'Not recorded' %></div>
            </div>
            <div class="bg-dark-card rounded-xl p-4 border border-red-500/20">
              <div class="text-xs text-text-muted uppercase mb-1">User Agent</div>
              <div class="text-white font-semibold text-sm break-all"><%= payment.userAgent || 'Not recorded' %></div>
            </div>
          </div>
        </div>
        <% } %>
      </div>

      <div class="grid md:grid-cols-2 gap-6" data-aos="fade-up" data-aos-delay="200">
        <a href="/invoice/<%= payment.transactionID %>/download" class="bg-accent hover:bg-accent/90 text-white px-8 py-4 rounded-xl font-bold transition-all duration-300 flex items-center justify-center gap-3 hover-lift shadow-lg">
          <i class="fas fa-file-download text-xl"></i>
          <span>Download PDF Invoice</span>
        </a>
        <a href="/profile" class="bg-dark-card hover:bg-dark-border text-white border border-white/20 px-8 py-4 rounded-xl font-bold transition-all duration-300 flex items-center justify-center gap-3 hover-lift">
          <i class="fas fa-box-open text-xl"></i>
          <span>View My Products</span>
        </a>
      </div>

      <div class="text-center mt-12 glass-effect rounded-2xl p-8" data-aos="fade-up" data-aos-delay="300">
        <i class="fas fa-heart text-red-400 text-3xl mb-4 animate-bounce-gentle"></i>
        <h3 class="text-2xl font-bold text-white mb-2">Thank You for Your Purchase!</h3>
        <p class="text-text-secondary max-w-2xl mx-auto">
          Your purchase helps us continue providing quality products and services.
          If you have any questions or need support, please don't hesitate to contact us.
        </p>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    AOS.init({
      duration: 400,
      easing: 'ease-out',
      once: true,
      offset: 50
    });
  </script>
</body>

</html>
